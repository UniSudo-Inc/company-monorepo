---
import { Icon } from 'astro-icon/components';
import Beams from './components/Beams.astro';
import VisualAnalysis from './components/VisualAnalysis.astro';
import AIInsightEngine from './components/AIInsightEngine.astro';
import Layout from '@/layouts/LandingLayout.astro';
import { getHomePermalinkEn } from '@/utils/permalinks';

const metadata = {
  title: 'UniTeach AI - AI-Powered Grading for Every Exam',
};

const subjects = [
  { icon: "lucide:atom", name: "Physics", en: "PHYSICS", color: "text-blue-500", bg: "bg-blue-50" },
  { icon: "lucide:flask-conical", name: "Chemistry", en: "CHEMISTRY", color: "text-green-500", bg: "bg-green-50" },
  { icon: "lucide:dna", name: "Biology", en: "BIOLOGY", color: "text-emerald-500", bg: "bg-emerald-50" },
  { icon: "lucide:scroll-text", name: "History", en: "HISTORY", color: "text-orange-500", bg: "bg-orange-50" },
  { icon: "lucide:globe", name: "Geography", en: "GEOGRAPHY", color: "text-cyan-500", bg: "bg-cyan-50" },
  { icon: "lucide:landmark", name: "Politics", en: "POLITICS", color: "text-red-500", bg: "bg-red-50" },
  { icon: "lucide:calculator", name: "Math", en: "MATH", color: "text-indigo-500", bg: "bg-indigo-50" },
  { icon: "lucide:book-open", name: "Chinese", en: "CHINESE", color: "text-rose-500", bg: "bg-rose-50" },
  { icon: "lucide:languages", name: "English", en: "ENGLISH", color: "text-purple-500", bg: "bg-purple-50" }
];

const pricingPlans = [
  { 
    name: "SaaS Subscription", 
    price: "100K", 
    unit: "/year", 
    desc: "Including maintenance, ready to use",
    features: ["Standard grading", "Cloud OCR", "Regular system updates", "Basic tech support"]
  },
  { 
    name: "Cloud Basic", 
    price: "300K", 
    unit: "One-time", 
    desc: "Integrates with your existing system",
    features: ["Grading core engine", "Cloud OCR/LLM", "System integration support", "15% annual maintenance"],
    popular: true
  },
  { 
    name: "Private Deployment", 
    price: "500K", 
    unit: "One-time", 
    desc: "Fully private deployment",
    features: ["Local OCR engine", "Custom frontend", "Full permission management", "15% annual maintenance"]
  }
];
---

<Layout metadata={metadata}>
  <div class="min-h-screen transition-colors duration-300">
    {/* 01 | Hero Section */}
    <header class="relative pt-16 pb-32 overflow-hidden">
      <Beams className="opacity-50 dark:opacity-0" />
      
      <div class="container mx-auto px-12 relative z-10">
        <div class="grid lg:grid-cols-[1fr_480px] gap-20 items-center">
          <div class="relative">
            <div class="stat-badge mb-8 w-fit inline-block px-4 py-1.5 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10">
              UniTeach AI v2.0
            </div>
            <h1 class="text-5xl md:text-7xl font-display font-black mb-8 leading-[1.1] tracking-tight">
              AI-Powered Grading <br />
              <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent italic">for Every Exam Paper</span>
            </h1>
            <p class="text-lg md:text-xl text-text-muted mb-12 max-w-xl leading-relaxed">
              Full subject coverage with high-precision OCR and LLM technology, providing private and intelligent grading solutions for schools.
            </p>
            <div class="flex flex-wrap gap-6">
              <a href="https://uniteach.unisudo.dev/" target="_blank" class="btn-primary">Try Demo</a>
              <a href="/en/en/contact/" class="px-8 py-4 bg-surface border border-border-light dark:border-primary/20 rounded-2xl font-bold hover:bg-bg transition-all">Contact Us</a>
            </div>
          </div>
          <div class="relative hero-image-container">
            <div class="aspect-[4/5] rounded-[40px] overflow-hidden border border-border-light dark:border-primary/20 shadow-[0_40px_100px_rgba(0,0,0,0.1)] bg-surface relative p-8">
              <div class="absolute inset-0 bg-gradient-to-br from-primary/5 to-transparent pointer-events-none"></div>
              <div class="bg-surface rounded-2xl h-full shadow-inner border border-border-light dark:border-primary/20 flex flex-col overflow-hidden">
                <div class="h-12 border-b border-border-light  dark:border-primary/20 flex items-center px-5 gap-2 bg-surface/50">
                  <div class="flex gap-1.5">
                    <div class="w-3 h-3 rounded-full bg-red-400/20 border border-red-400/40"></div>
                    <div class="w-3 h-3 rounded-full bg-yellow-400/20 border border-yellow-400/40"></div>
                    <div class="w-3 h-3 rounded-full bg-green-400/20 border border-green-400/40"></div>
                  </div>
                  <div class="flex-1 text-center">
                    <span class="text-[11px] text-text-muted font-mono bg-surface px-4 py-1 rounded-full border border-border-light dark:border-primary/20 shadow-sm">uniteach-analysis-v2.pdf</span>
                  </div>
                </div>
                <div class="p-6 flex flex-col gap-6 h-full">
                  <div class="flex-1 p-5 rounded-2xl border border-border-light  dark:border-primary/20 bg-surface relative overflow-hidden group shadow-sm">
                    <div class="absolute left-0 w-full h-[3px] bg-primary/40 shadow-[0_0_20px_rgba(124,58,237,0.6)] z-10 animate-scan"></div>
                    <div class="space-y-4 opacity-30">
                      <div class="flex justify-between items-center">
                        <div class="w-1/3 h-3 bg-text-muted/20 rounded"></div>
                        <div class="w-12 h-3 bg-text-muted/20 rounded"></div>
                      </div>
                      <div class="w-full h-2 bg-surface rounded-lg"></div>
                      <div class="w-[85%] h-2 bg-surface rounded-lg"></div>
                      <div class="w-full p-4 border-2 border-dashed border-border-light dark:border-primary/20 rounded-2xl space-y-4 bg-surface/50">
                        <div class="flex gap-2">
                          <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center text-[10px] font-bold text-primary">Q1</div>
                          <div class="flex-1 space-y-2">
                            <div class="h-2 w-full bg-text-muted/20 rounded"></div>
                            <div class="h-2 w-3/4 bg-text-muted/20 rounded"></div>
                          </div>
                        </div>
                        <div class="h-24 w-full bg-text-muted/5 rounded-xl flex flex-col items-center justify-center p-4 border border-border-light  dark:border-primary/20">
                          <div class="text-[10px] font-serif italic text-text-muted mb-2">∫ sin(x) / e^x dx</div>
                          <div class="w-full h-px bg-border/50 my-2"></div>
                          <div class="text-[9px] font-serif italic text-primary/60">Recognition: 99.2%</div>
                        </div>
                      </div>
                    </div>
                    <div class="absolute inset-0 flex items-center justify-center">
<div class="px-6 py-3 rounded-2xl bg-primary/95 backdrop-blur-md text-white text-xs font-bold shadow-[0_10px_30px_rgba(124,58,237,0.4)] animate-pulse border border-white/20">
                          AI Analyzing...
                        </div>
                    </div>
                  </div>
                  <div class="grid grid-cols-2 gap-4">
                    <div class="p-5 rounded-2xl border border-border-light dark:border-primary/20 bg-surface shadow-sm">
                      <div class="flex justify-between items-center mb-4">
                        <div class="tag">Mastery</div>
                        <div class="text-xs font-bold text-primary">82%</div>
                      </div>
                      <div class="text-base font-bold mb-2">Plane Vectors</div>
                      <div class="w-full h-2 bg-surface rounded-full overflow-hidden">
                        <div class="h-full bg-primary animate-width-82"></div>
                      </div>
                    </div>
                    <div class="p-5 rounded-2xl border border-primary/20 bg-primary/5 shadow-sm">
                      <div class="tag bg-primary/10 text-primary mb-4">Smart Suggestions</div>
                      <div class="space-y-2 mb-4">
                        <div class="w-full h-1.5 bg-primary/10 rounded-full"></div>
                        <div class="w-[80%] h-1.5 bg-primary/10 rounded-full"></div>
                      </div>
                      <p class="text-[10px] text-primary/70 leading-relaxed font-medium">Recommend topic-based practice.</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="absolute -bottom-10 -left-10 w-40 h-40 bg-accent/20 blur-[60px] rounded-full -z-10 animate-pulse"></div>
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-primary/20 blur-[60px] rounded-full -z-10 animate-pulse"></div>
          </div>
        </div>
      </div>
    </header>

    {/* Section Header Template */}
    <section class="py-32 bg-bg relative overflow-hidden">
      <div class="absolute top-0 right-0 w-1/3 h-full bg-gradient-to-l from-primary/5 to-transparent"></div>
      <div class="container mx-auto px-12 relative z-10">
        <div class="grid lg:grid-cols-2 gap-24 items-center">
          <div>
            <div class="mb-16 text-left">
              <span class="stat-badge px-4 py-1.5 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10 mb-4 inline-block">Industry Insights</span>
<h2 class="text-3xl md:text-5xl font-display font-bold mb-6 tracking-tight text-text">The Last Bottleneck in Digital Education</h2>
              <p class="text-base md:text-lg text-text-muted leading-relaxed">Grading still relies on heavy manual work, limiting teaching efficiency.</p>
            </div>
            <div class="space-y-6">
              {[
                { icon: "lucide:clock", text: "Teachers spend 70% of their time on grading", detail: "Teachers are forced to become 'grading machines', unable to focus on teaching." },
                { icon: "lucide:layers", text: "Low accuracy in hand-written formula recognition", detail: "Generic OCR struggles with complex science formulas and cursive handwriting." },
                { icon: "lucide:bar-chart-3", text: "Data cannot form a closed loop", detail: "Graded scores are just numbers, lacking deep knowledge point correlation." }
              ].map((item) => (
                <div class="flex gap-6 p-8 rounded-[32px] bg-surface border border-border-light dark:border-primary/20 shadow-sm hover:shadow-md transition-shadow">
                  <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shrink-0">
                    <Icon name={item.icon} class="w-7 h-7" />
                  </div>
                  <div>
                    <h4 class="text-xl font-bold mb-2">{item.text}</h4>
                    <p class="text-text-muted text-sm leading-relaxed">{item.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="relative">
            <div class="grid grid-cols-2 gap-6">
              <div class="space-y-6 pt-12">
                <div class="bento-card-stat bg-primary text-white p-10 rounded-[40px] shadow-sm">
                  <div class="text-4xl font-display font-black mb-2">70%</div>
                  <div class="text-xs font-bold uppercase tracking-widest opacity-80">Time Saved</div>
                </div>
                <div class="bento-card p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm">
                  <div class="text-4xl font-display font-black mb-2 text-primary">99%</div>
                  <div class="text-xs font-bold uppercase tracking-widest text-text-muted">Recognition Accuracy</div>
                </div>
              </div>
              <div class="space-y-6">
                <div class="bento-card p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm">
                  <div class="text-4xl font-display font-black mb-2 text-accent">24/7</div>
                  <div class="text-xs font-bold uppercase tracking-widest text-text-muted">Real-time Feedback</div>
                </div>
                <div class="bento-card p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm">
                  <div class="text-4xl font-display font-black mb-2 text-primary">100%</div>
                  <div class="text-xs font-bold uppercase tracking-widest text-text-muted">Private Deployment</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Solutions Section */}
    <section class="py-32" id="solutions">
      <div class="container mx-auto px-12">
        <div class="mb-16 text-center">
          <span class="stat-badge px-4 py-1.5 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10 mb-4 inline-block">Product Positioning</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 tracking-tight text-text">UniTeach: AI-Powered Grading Expert</h2>
          <p class="text-base md:text-lg text-text-muted leading-relaxed mx-auto max-w-2xl">AI automatic grading and teaching assessment system for schools</p>
        </div>
        
        <div class="grid md:grid-cols-3 gap-8">
          {[
            { icon: "lucide:globe", title: "Multi-Channel Support", desc: "Supports paper, PDF, and image inputs, adapting to various teaching scenarios.", tag: "CHANNELS" },
            { icon: "lucide:brain", title: "Smart Routing", desc: "Automatically matches grading logic to ensure accurate recognition.", tag: "ROUTING" },
            { icon: "lucide:graduation-cap", title: "Full Question Coverage", desc: "Supports multiple choice, fill-in, calculation, proof, and drawing questions.", tag: "COVERAGE" }
          ].map((item) => (
            <div class="bento-card group p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm hover:shadow-xl transition-all">
              <div class="tag mb-4 w-fit px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest border border-current">{item.tag}</div>
              <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center mb-6 group-hover:bg-primary group-hover:text-white transition-colors">
                <Icon name={item.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold mb-3 text-text">{item.title}</h3>
              <p class="text-text-muted leading-relaxed">{item.desc}</p>
            </div>
          ))}
        </div>
        
        <div class="mt-12 grid md:grid-cols-2 gap-8">
          <div class="p-12 rounded-[40px] bg-bg-dark text-text dark:text-white flex flex-col justify-between relative overflow-hidden group border border-border-light  dark:border-primary/20 transition-all hover:shadow-xl">
            <div class="absolute top-0 right-0 w-64 h-64 bg-primary/10 blur-[80px] -translate-y-1/2 translate-x-1/2"></div>
            <div class="relative z-10">
              <h3 class="text-3xl font-display font-bold mb-6">From "Grading" to<br />"Teaching Data Assets"</h3>
              <p class="text-text-muted dark:text-white/60 mb-12 text-lg leading-relaxed">We don't just grade papers - we help schools build core teaching assets, enabling the shift from grade mistakes to precision teaching.</p>
            </div>
            <a href="https://uniteach.unisudo.dev/" target="_blank" class="flex items-center gap-2 text-primary font-bold cursor-pointer group-hover:gap-4 transition-all">
              Learn More <Icon name="lucide:chevron-right" class="w-5 h-5" />
            </a>
          </div>
          <div class="p-12 rounded-[40px] bg-accent text-white flex flex-col justify-between relative overflow-hidden group transition-all hover:shadow-xl">
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-white/10 blur-[80px] translate-y-1/2 translate-x-1/2"></div>
            <div class="relative z-10">
              <h3 class="text-3xl font-display font-bold mb-6">Flexible Scoring Logic</h3>
              <p class="text-white/60 mb-12 text-lg leading-relaxed">Supports different scoring logic within exercises, accurately replicating teacher grading thinking to ensure fairness.</p>
            </div>
            <a href="https://uniteach.unisudo.dev/" target="_blank" class="flex items-center gap-2 text-white/90 font-bold cursor-pointer group-hover:gap-4 transition-all">
              View Case Studies <Icon name="lucide:chevron-right" class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* AI Analysis Section */}
    <section class="py-32 bg-bg relative overflow-hidden">
      <div class="container mx-auto px-12 relative z-10">
        <div class="mb-16">
          <div class="mb-16 text-center">
            <span class="stat-badge px-4 py-1.5 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10 mb-4 inline-block">Solutions</span>
            <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 tracking-tight text-text">Conquering AI Recognition Blind Spots</h2>
            <p class="text-base md:text-lg text-text-muted leading-relaxed mx-auto max-w-2xl">UniTeach achieves industrial-grade recognition accuracy through vertical domain fine-tuning.</p>
          </div>
          <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
            {[
              { icon: "lucide:mic", title: "Full Subject High-Precision Recognition", desc: "Deeply optimized math formulas, chemical symbols, leading accuracy.", tag: "OCR Tech" },
              { icon: "lucide:shield-check", title: "Privacy & Data Security", desc: "Fully local offline deployment, student info stays at school.", tag: "Privacy" },
              { icon: "lucide:cpu", title: "Low Deployment Cost", desc: "No expensive hardware, software-only solution, lowers AI barriers.", tag: "Cost" },
              { icon: "lucide:settings", title: "Self-Training Support", desc: "Supports vertical scenarios like IELTS, essay OCR fine-tuning.", tag: "Customization" }
            ].map((item) => (
              <div class="p-6 rounded-2xl bg-surface border border-border-light dark:border-primary/20 hover:shadow-md transition-all">
                <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-4">
                  <Icon name={item.icon} class="w-5 h-5" />
                </div>
                <h4 class="font-bold mb-2 text-text">{item.title}</h4>
                <p class="text-xs text-text-muted leading-relaxed">{item.desc}</p>
              </div>
            ))}
          </div>
          <div class="relative animate-fade-in-up">
            <AIInsightEngine />
            <div class="absolute -bottom-20 -left-20 w-80 h-80 bg-primary/10 blur-[120px] rounded-full -z-10"></div>
            <div class="absolute -top-20 -right-20 w-80 h-80 bg-accent/10 blur-[120px] rounded-full -z-10"></div>
          </div>
        </div>
      </div>
    </section>

    {/* Subject Coverage Section */}
    <section class="py-32 bg-bg">
      <div class="container mx-auto px-12">
        <div class="grid lg:grid-cols-2 gap-24 items-center">
          <div class="grid grid-cols-3 gap-6">
            {subjects.map((subject) => (
              <div class="aspect-square rounded-3xl bg-surface border border-border-light  dark:border-primary/20 flex flex-col items-center justify-center gap-3 group hover:shadow-xl transition-all">
                <div class={`w-12 h-12 rounded-2xl ${subject.bg} ${subject.color} flex items-center justify-center group-hover:scale-110 transition-transform`}>
                  <Icon name={subject.icon} class="w-6 h-6" />
                </div>
                <div class="text-center">
                  <div class="font-bold text-sm">{subject.name}</div>
                  <div class="text-[10px] text-text-muted font-bold tracking-widest uppercase">{subject.en}</div>
                </div>
              </div>
            ))}
          </div>
          <div class="relative">
            <div class="absolute -top-10 -left-10 w-32 h-32 bg-primary/10 blur-[60px] rounded-full"></div>
            <div class="relative z-10 space-y-8 text-left">
              <span class="stat-badge px-3 py-1 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10">CORE ARCHITECTURE</span>
              <h2 class="text-4xl font-display font-bold tracking-tight leading-tight">
                All Subjects, All Question Types <br />
                <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">Deep Intelligent Coverage</span>
              </h2>
              <p class="text-lg text-text-muted leading-relaxed">
                Intelligent routing engine automatically distributes tasks, achieving unified processing of paper homework, PDF, and image data. Covers all core subjects, automatically generating structured teaching assets.
              </p>
              <div class="grid grid-cols-2 gap-8 pt-8">
                <div>
                  <div class="text-4xl font-display font-black text-primary mb-2">100%</div>
                  <div class="text-sm font-bold text-text-muted uppercase tracking-widest">Question Type Coverage Rate</div>
                </div>
                <div>
                  <div class="text-4xl font-display font-black text-accent mb-2">9+</div>
                  <div class="text-sm font-bold text-text-muted uppercase tracking-widest">Core Subjects</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Capabilities Section */}
    <section class="py-32 bg-surface" id="features">
      <div class="container mx-auto px-12">
        <div class="mb-16 text-center">
          <span class="stat-badge px-4 py-1.5 bg-primary/5 text-primary rounded-full text-[10px] font-bold uppercase tracking-widest border border-primary/10 mb-4 inline-block">Core Capabilities</span>
          <h2 class="text-3xl md:text-5xl font-display font-bold mb-6 tracking-tight text-text">Full-Chain AI Empowerment System</h2>
          <p class="text-base md:text-lg text-text-muted leading-relaxed mx-auto max-w-2xl">From high-precision recognition to deep diagnosis, UniTeach creates a complete intelligent teaching closed loop.</p>
        </div>
        
        <div class="grid lg:grid-cols-3 gap-8">
          <div class="lg:col-span-2 bento-card flex flex-col md:flex-row gap-12 items-center group">
            <div class="md:w-1/2">
              <div class="tag mb-6 text-primary border-primary">ALL-IN-ONE</div>
              <h3 class="text-2xl font-display font-bold mb-6">All-Subject Intelligent Recognition</h3>
              <p class="text-base text-text-muted mb-8 leading-relaxed">Covers math, Chinese, science and more. Supports calculation, proof, drawing and all question types.</p>
              <div class="flex gap-4">
                <div class="tag bg-primary/10 text-primary border-primary/20">All Subject Coverage</div>
                <div class="tag bg-accent/10 text-accent border-accent/20">All Question Type Support</div>
              </div>
            </div>
            <div class="md:w-1/2 relative">
              <VisualAnalysis />
            </div>
          </div>

          <div class="bento-card group p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm hover:shadow-xl transition-all">
            <div class="tag mb-6 border-slate-400 text-slate-500">EDITOR</div>
            <h3 class="text-2xl font-display font-bold mb-4">Intelligent Template Editor</h3>
            <p class="text-text-muted leading-relaxed">AI automatically identifies question areas, supporting WYSIWYG fine-tuning. Configure once, use across the school.</p>
            <div class="mt-8 pt-8 border-t border-border-light  dark:border-primary/20 flex justify-between items-center">
              <a href="https://uniteach.unisudo.dev/" target="_blank" class="text-xs font-bold text-primary uppercase tracking-widest">Learn More</a>
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-primary group-hover:translate-x-1 transition-transform" />
            </div>
          </div>

          <div class="bento-card group p-10 rounded-[40px] bg-surface border border-border-light  dark:border-primary/20 shadow-sm hover:shadow-xl transition-all">
            <div class="tag mb-6 border-slate-400 text-slate-500">ALGORITHM</div>
            <h3 class="text-2xl font-display font-bold mb-4">Step-by-Step Scoring Algorithm</h3>
            <p class="text-text-muted leading-relaxed">Not just checking answers, but understanding solving steps. Automatically categorizes similar wrong approaches for precise remediation.</p>
            <div class="mt-8 pt-8 border-t border-border-light  dark:border-primary/20 flex justify-between items-center">
              <a href="https://uniteach.unisudo.dev/" target="_blank" class="text-xs font-bold text-primary uppercase tracking-widest">Learn More</a>
              <Icon name="lucide:arrow-right" class="w-4 h-4 text-primary group-hover:translate-x-1 transition-transform" />
            </div>
          </div>

          <div class="lg:col-span-2 grid md:grid-cols-2 gap-8">
            <div class="bento-card bg-bg-dark text-text border-none relative overflow-hidden group p-10 rounded-[40px] shadow-sm hover:shadow-xl transition-all">
