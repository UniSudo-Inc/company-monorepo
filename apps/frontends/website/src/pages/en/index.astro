---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const products = [
  {
    id: "a2",
    title: "Intelligent Employee (AG2O)",
    tagline: "Resident Personal Intelligent Operating System",
    desc: "More than an AI assistant, it's your personal intelligent team. Built on Rust, it supports layered collaboration, parallel execution, and long-term memory accumulation.",
    icon: "lucide:message-square",
    color: "from-blue-500 to-indigo-600",
    href: "/en/products/ag2o/"
  },
  {
    id: "a1",
    title: "No-Code AI Platform (A1)",
    tagline: "Enterprise Digital Foundation",
    desc: "One-stop no-code AI application development platform. Build complex AI workflows through drag-and-drop, compatible with major domestic and international LLMs, quickly empowering business scenarios.",
    icon: "lucide:cpu",
    color: "from-purple-500 to-violet-600",
    href: "https://a1.v8.unisudo.dev/"
  },
  {
    id: "uniteach",
    title: "AI Intelligent Grading (UniTeach)",
    tagline: "Deep Education Industry Review",
    desc: "Intelligent evaluation system focused on education vertical. Supports multi-modal recognition and personalized comment generation, making teaching evaluation more objective and efficient.",
    icon: "lucide:graduation-cap",
    color: "from-orange-500 to-red-600",
    href: "/en/products/uniteach/"
  },
  {
    id: "unibusiness",
    title: "Cross-border Meeting Interpretation (UniBusiness)",
    tagline: "Cross-language Collaboration Tool",
    desc: "Real-time AI meeting interpretation. Supports major meeting software, provides real-time translation, bilingual understanding, and intelligent meeting notes, boosting global efficient collaboration.",
    icon: "lucide:languages",
    color: "from-emerald-500 to-teal-600",
    href: "/en/products/unibusiness/"
  },
  {
    id: "uniclause",
    title: "Intelligent Contract Review (UniClause)",
    tagline: "Explainable Risk Control",
    desc: "Deep contract analysis platform based on RAG architecture. Every contract review can be traced, accurately identifying risks and generating revision suggestions.",
    icon: "lucide:shield-check",
    color: "from-indigo-500 to-purple-600",
    href: "/en/products/uniclause/"
  }
];

const stats = [
  { label: "Enterprises Served", value: "200+" },
  { label: "Average Efficiency", value: "75%" },
  { label: "Model Processing", value: "10B+" },
  { label: "Data Security", value: "Financial Level" }
];

const coreCompetencies = [
  {
    title: 'Technology Innovation',
    description: 'Break through traditional architecture limitations to achieve low-cost, high-efficiency AI solutions.',
    icon: 'lucide:rocket',
  },
  {
    title: 'Scene Understanding',
    description: 'Deeply understand vertical domain needs to provide precise industry solutions.',
    icon: 'lucide:component',
  },
  {
    title: 'Cost Advantage',
    description: 'Significantly reduce deployment and operational costs through innovative technology architecture.',
    icon: 'lucide:coins',
  },
  {
    title: 'Complete Ecosystem',
    description: 'Independently develop full-process technology chain to provide one-stop service capabilities.',
    icon: 'lucide:layers',
  },
];

const solutions = [
  {
    title: "Virtual Digital Humans & Streaming Conversations",
    subtitle: "Millisecond-level real-time interaction that brings digital showrooms and intelligent customer service to life.",
    category: "Interactive Innovation",
    image: "https://images.openai.com/static-rsc-4/8PPBBVXur7C-XIWP1_phZtYp55i3isw-Vb-45CD9lUCMQjg2WqrvIyV-Z_fQhGwvRQsOy3DlxLGvK2j51YTNOvQR1TeMWQH5lDkwGQqbuwLRcz0_PpLDOnoQ8U7VCtKw9zzT4_iMbVijDc_ruuFbgLnFC8yMHxGVjd5NTod20h_ZJiqyLGvghp73_mKzZXLt?purpose=inline",
    items: [
      "Industry-leading interruptible streaming technology",
      "High-fidelity digital human rendering",
      "Deep multi-turn conversational memory",
      "Ultra-low latency end-to-end response"
    ]
  },
  {
    title: "Edge Computing Hardware Solutions",
    subtitle: "Deeply customized software-hardware integration for industrial-grade private model deployment and data security.",
    category: "Infrastructure",
    image: "https://images.openai.com/static-rsc-4/FyUWuvjde8DLAJvTwXLOnt4mrvxJ5BieHOYaK6SBtSCQnVXJJljMsBshKLy5cvHgeM-BaEBJXtwXPnr5XcXh-41jX84FfjFtu6B9_Jw9r_sInVcYRXNj-jAGJmCupfzVKn5DcRuo5sHXYrzQONfwAAWy-mIrxSoJugM8jGEEft0EFKTnhYTcDulFsBHNuzNM?purpose=inline",
    items: [
      "Support for localized and domestic computing architectures",
      "Flexible integration with multi-vendor sensor interfaces",
      "Private model compression and quantization optimization",
      "Industrial-grade 24/7 stable operation"
    ]
  },
  {
    title: "Enterprise-Grade Cloud-Native Workflows",
    subtitle: "Bridging AI applications and business systems to enable fully automated process transformation.",
    category: "Organizational Efficiency",
    image: "https://images.openai.com/static-rsc-4/rClkOUPwQtWlbhC1QbL-0MuSIks_gezzFmbBP4a8n7qFG7cl_8TveMpaAsrRKu_dttBGz-eMx2_abJ-vhimVkRaIuzrjqhoX5qHeT9sOcKqeuVVHXQ_GI6X1rTcJtAVfWd7pVuF7sT3bEdqhH-xhJB6bOmcQ4oZLETr-aNTp_ciJqZEePfiiCVQOzMWjENlz?purpose=inline",
    items: [
      "Standardized Function Call plugin ecosystem",
      "Elastic and scalable cloud-native API clusters",
      "Granular token usage monitoring",
      "Multi-role collaborative workflow engine"
    ]
  }
];

const scenarios = [
  {
    title: 'Digital Human Exhibition',
    description: ['Bank Intelligent Net Digital Employee', 'Museum Virtual Guide', 'Enterprise Exhibition Interactive Guide', 'Shopping Mall Digital Guide Assistant'],
    icon: 'lucide:user',
  },
  {
    title: 'Data Services',
    description: ['AI Training Data Annotation', 'Multi-modal Data Processing', 'Data Cleaning and Enhancement', 'Data Quality Evaluation System'],
    icon: 'lucide:database',
  },
  {
    title: 'Model Training',
    description: ['Large Language Model Fine-tuning', 'Vertical Domain Model Development', 'Multi-modal Model Deployment', 'Model Performance Optimization'],
    icon: 'lucide:brain',
  },
  {
    title: 'Intelligent Customer Service',
    description: ['Financial Services Intelligent Q&A', 'E-commerce Customer Service Robot', 'Multi-turn Dialogue Management', 'Emotion Recognition Service'],
    icon: 'lucide:headset',
  },
  {
    title: 'Enterprise Digitalization',
    description: ['Smart Talent Screening', 'Enterprise Training Assistant', 'Office Automation Platform', 'Auxiliary Decision System'],
    icon: 'lucide:building',
  },
  {
    title: 'Industry Solutions',
    description: ['Education Training Digitalization', 'Medical Health Intelligent Diagnosis', 'Financial Risk Analysis', 'Retail Intelligent Upgrade'],
    icon: 'lucide:bar-chart-3',
  },
];

const metadata = {
  title: 'UniSudo Inc. — Unique AI Solutions for SUDO Permissions',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Dynamic Background -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
  </div>

  <main class="relative z-10">
    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center relative overflow-hidden">
      <div class="animate-on-scroll">
        <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
          SUDO Permissions · Unique AI Solutions
        </span>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 100ms">
        <h1 class="text-5xl md:text-7xl font-black mb-8 leading-[1.1] tracking-tighter max-w-5xl">
          Unique AI Solutions for <br />
          <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">SUDO Permissions</span>
        </h1>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 200ms">
        <p class="text-xl text-muted max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
          <span class="font-bold text-primary block mb-2 md:inline md:mb-0">UniSudo Inc.</span>
          is dedicated to creating high-performance, low-cost AI solutions. Through innovative model architectures and full-process technical support, we help enterprises implement AI precisely at a cost far lower than traditional solutions.
        </p>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 300ms">
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="#products">
            <button class="btn-primary text-lg px-8 py-4">
              Product Matrix
            </button>
          </a>
          <a href="/en/about/" class="px-8 py-4 rounded-full border border-gray-200  dark:border-primary/20 font-medium hover:bg-black/5 dark:hover:bg-white/5 transition-all">
            Company Introduction
          </a>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="animate-on-scroll mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-20" style="transition-delay: 400ms">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold mb-1 tracking-tight">{s.value}</div>
            <div class="text-xs text-muted font-bold uppercase tracking-widest">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Core Competency Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto border-t border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll text-center mb-20">
        <span class="text-primary font-bold tracking-widest uppercase text-xs mb-4 block">Core Competency</span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6">Industry Experts + Innovative Thinking + Technology R&D</h2>
        <p class="text-muted text-lg max-w-3xl mx-auto">
          UniSudo Inc. continues to deepen technological innovation, focusing on providing more efficient and cost-effective AI deployment solutions for enterprises.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {coreCompetencies.map((c, i) => (
          <div class="animate-on-scroll p-8 rounded-3xl bg-white dark:bg-[#030620] border border-gray-100  dark:border-primary/20 group hover:border-primary/50 transition-all duration-500" style={`transition-delay: ${i * 100}ms`}>
            <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
              <Icon name={c.icon} class="w-6 h-6" />
            </div>
            <h3 class="text-xl font-bold mb-4">{c.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Solutions Showcase Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto bg-surface-light dark:bg-surface-dark/30 rounded-[3rem] overflow-hidden border border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">Meet All Your AI Needs</h2>
        <p class="text-muted text-lg">Matrix product system, empowering enterprise full lifecycle digital transformation</p>
      </div>

      <div class="space-y-40">
        {solutions.map((s, i) => (
          <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-16 items-center lg:items-center`}>
            <div class="reveal lg:w-3/5" style={`transition-delay: ${i * 100}ms`}>
              <div class="relative group perspective-1000">
                <div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-[4rem] blur-2xl opacity-0 group-hover:opacity-100 transition-all duration-700 -z-10 scale-95 group-hover:scale-105"></div>
                <div class="overflow-hidden rounded-[3rem] border border-border-light dark:border-white/10 shadow-2xl transition-transform duration-700 group-hover:scale-[1.02]">
                  <img 
                    src={s.image} 
                    alt={s.title} 
                    referrerpolicy="no-referrer"
                    class="w-full object-cover aspect-[16/10] grayscale-[0.3] group-hover:grayscale-0 transition-all duration-700" 
                  />
                </div>
                <!-- Decorative Badge -->
                <div class="absolute -bottom-6 -right-6 md:right-12 bg-white dark:bg-[#030620] px-8 py-4 rounded-2xl shadow-xl border border-border-light dark:border-primary/20 hidden md:block">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-primary animate-ping"></div>
                    <span class="text-xs font-black uppercase tracking-[0.2em]">{s.category}</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="reveal lg:w-2/5" style={`transition-delay: ${(i * 100) + 150}ms`}>
              <div class="flex items-center gap-3 mb-6">
                 <span class="w-12 h-px bg-primary/30"></span>
                 <span class="text-xs font-bold text-primary uppercase tracking-[0.3em]">{s.category}</span>
              </div>
              <h3 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter italic leading-tight">{s.title}</h3>
              <p class="text-lg text-muted mb-10 leading-relaxed font-medium italic pr-4">{s.subtitle}</p>
              <div class="grid grid-cols-1 gap-4">
                {s.items.map(item => (
                  <div class="flex items-center gap-4 group/item">
                    <div class="w-8 h-8 rounded-lg bg-primary/5 flex items-center justify-center text-primary group-hover/item:bg-primary group-hover/item:text-white transition-all duration-300">
                      <Icon name="lucide:arrow-right-circle" class="w-4 h-4" />
                    </div>
                    <span class="text-sm font-bold text-muted group-hover/item:text-default transition-colors">{item}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- AI Application Scenarios -->
    <section class="py-32 px-6 max-w-7xl mx-auto">
      <div class="animate-on-scroll text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">AI Application Scenarios</h2>
        <p class="text-muted text-lg">Empowering multiple vertical fields including intelligent manufacturing, transportation, customer service, and enterprise services</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {scenarios.map((s, i) => (
          <div class="animate-on-scroll bento-card flex flex-col group" style={`transition-delay: ${i * 100}ms`}>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold">{s.title}</h3>
            </div>
            <ul class="space-y-3">
              {s.description.map(item => (
                <li class="text-sm text-muted flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-primary/30 rounded-full"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Product Matrix Section -->
    <section id="products" class="py-32 px-6 max-w-7xl mx-auto border-t border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">Product Matrix</h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">High-end AI product line built for specific pain points.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((p, i) => (
          <a href={p.href} target={p.id==='a1' ? '_blank' : undefined} class="animate-on-scroll group block" style={`transition-delay: ${i * 100}ms`}>
            <div class="bento-card h-full flex flex-col p-8 group-hover:border-primary/50 transition-all duration-500 overflow-hidden relative">
              <div class={`absolute -top-10 -right-10 w-40 h-40 bg-gradient-to-br ${p.color} opacity-[0.03] group-hover:opacity-10 rounded-full blur-3xl transition-opacity duration-700`}></div>
              <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${p.color} flex items-center justify-center text-white mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500`}>
                <Icon name={p.icon} class="w-7 h-7" />
              </div>
              <div class="flex-grow">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-bold uppercase tracking-widest text-primary opacity-70">{p.tagline}</span>
                  <Icon name="lucide:arrow-right" class="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" />
                </div>
                <h3 class="text-2xl font-bold mb-4 tracking-tight">{p.title}</h3>
                <p class="text-muted leading-relaxed text-sm">{p.desc}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Unified Experience Block -->
    <section id="about" class="py-24 px-6 max-w-7xl mx-auto">
      <div class="animate-on-scroll bento-card border-none bg-gradient-to-br from-indigo-900 to-purple-900 text-white p-12 md:p-20 overflow-hidden relative">
        <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/tech/1920/1080?blur=10')] opacity-20 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-2xl">
          <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-8 italic">Let AI Truly Dive into Business Scenarios</h2>
          <p class="text-lg text-white/80 mb-10 leading-relaxed font-medium">
            We not only provide tools, but also provide an intelligent business path with deep integration, security compliance and landing.
            UniSudo is your most reliable AI partner, whether it is privatization deployment or cloud collaboration.
          </p>
          <div class="flex gap-4">
            <a href="/en/contact/" class="bg-white text-indigo-900 px-8 py-3 rounded-full font-bold hover:bg-neutral-100 transition-colors">Contact Us</a>
            <a href="/en/career/" class="bg-white/10 text-white px-8 py-3 rounded-full font-bold backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">Join Us</a>
          </div>
        </div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[40%] h-[80%] hidden lg:block opacity-40">
           <div class="w-full h-full border-[20px] border-white/10 rounded-full animate-spin" style="animation-duration: 20s"></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .glass {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  
  :global(.dark) .glass {
    background: rgba(3, 6, 32, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>