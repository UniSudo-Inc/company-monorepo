---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: 'Enterprise Digitalization Solutions - UniSudo',
};

const stats = [
  { title: 'Service Efficiency', value: '200%+', desc: 'Average efficiency significantly improved', icon: 'lucide:zap' },
  { title: 'Operating Costs', value: '60%+', desc: 'Average expenses significantly reduced', icon: 'lucide:trending-down' },
  { title: 'Customer Satisfaction', value: '40%+', desc: 'Interaction experience deeply optimized', icon: 'lucide:smile' },
  { title: 'Data Security', value: '100%', desc: 'Local deployment fully controllable', icon: 'lucide:lock' }
];
---

<Layout metadata={metadata}>
  <main class="relative z-10 pt-0">
    <!-- Dynamic Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <!-- Hero Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center animate-on-scroll">
      <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
        SOLUTIONS · 企业数字化
      </span>
      <h1 class="text-6xl md:text-7xl font-black mb-8 tracking-tighter leading-[0.9]">
        Enterprise Digitalization<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent text-5xl md:text-6xl italic">Reshaping Industry Momentum</span>
      </h1>
      <p class="text-xl text-muted max-w-3xl mx-auto font-medium leading-relaxed">
        Local Deployment · 24/7 Service · Data Security. End-to-end AI-driven digital transformation solutions for enterprises, making technology truly serve productivity.
      </p>
    </section>

    <!-- Case Studies: Immersive Blocks -->
    <section class="py-32 space-y-40">
       <!-- Case 1: Finance -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
             <div class="animate-on-scroll animate-left">
                <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 inline-block">FINANCIAL · 金融服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">Financial Services Intelligent Q&A System</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-primary uppercase mb-3 text-primary/60">Project Background & Goals</p>
                      <p class="text-sm text-muted leading-relaxed">
                        Demand: Improve financial service response efficiency, reduce labor costs. Pain points: Frequent professional knowledge updates, high manual training costs, unstable service quality. Goal: Build a secure and reliable intelligent financial advisor.
                      </p>
                   </div>
                   <div class="p-8 rounded-[2.5rem] bg-slate-900 text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-10"><Icon name="lucide:cpu" class="w-24 h-24" /></div>
                      <h4 class="text-xl font-black mb-3 italic tracking-tight">Solution</h4>
                      <p class="text-sm text-white/70 leading-relaxed italic border-l-2 border-primary/50 pl-4">
                        Deploy 3B local small model to ensure data security. Build a professional financial domain knowledge base, support multi-turn dialogue understanding. Provide 7x24 professional consultation services, achieve precise financial product recommendations.
                      </p>
                   </div>
                   <div class="flex gap-6">
                      <div class="flex-1 p-8 rounded-[2.5rem] bg-emerald-500/5 border border-emerald-500/10">
                         <p class="text-3xl font-black italic text-emerald-500 tracking-tighter">95%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">Q&A Accuracy</p>
                      </div>
                      <div class="flex-1 p-8 rounded-[2.5rem] bg-primary/5 border border-primary/10">
                         <p class="text-3xl font-black italic text-primary tracking-tighter">-60%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">Labor Cost Reduction</p>
                      </div>
                   </div>
                   <div class="p-6 border-t border-border-light dark:border-primary/20   pt-8">
                      <h4 class="text-lg font-bold mb-3 flex items-center gap-2"><Icon name="lucide:sparkles" class="w-5 h-5 text-primary" /> Technical Highlights</h4>
                      <p class="text-xs text-muted leading-relaxed">Adopt 3B local small model deployment, no internet connection required, ensuring data security. Professional financial knowledge base makes answers more accurate, multi-turn dialogue capability makes service more natural. Only one ordinary server needed monthly to run, significantly reducing operating costs.</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right relative">
                <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 2: E-commerce -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center flex-row-reverse">
             <div class="animate-on-scroll animate-left lg:order-2">
                <span class="text-accent text-xs font-bold uppercase tracking-widest mb-4 inline-block">ECOMMERCE · 电商服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">E-commerce Full-process Customer Service Robot</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-accent uppercase mb-3 text-accent/60">Project Background & Goals</p>
                      <p class="text-sm text-muted leading-relaxed">
                        Demand: Improve e-commerce service efficiency, solve pre-sale and after-sale service pressure and holiday staffing shortage. Goal: Build a full-process intelligent service system including orders, logistics, and returns.
                      </p>
                   </div>
                   <div class="p-8 rounded-[3rem] bg-accent text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-20"><Icon name="lucide:shopping-bag" class="w-24 h-24" /></div>
                      <h4 class="text-xl font-black mb-3 italic tracking-tight">Solution</h4>
                      <p class="text-sm text-white/90 leading-relaxed italic border-l-2 border-white/50 pl-4">
                        Deploy 7B local model to protect data privacy. Achieve order inquiry and after-sales tracking, integrate product recommendation and price comparison, support intelligent returns/exchanges processing and global multi-language customer service.
                      </p>
                   </div>
                   <div class="grid grid-cols-3 gap-4">
                      <div class="p-6 rounded-3xl bg-accent/5 border border-accent/10 text-center">
                         <p class="text-2xl font-black italic text-accent pb-1">300%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">Capacity Increase</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-purple-500/5 border border-purple-500/10 text-center">
                         <p class="text-2xl font-black italic text-purple-500 pb-1">+25%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">Customer Unit Price Growth</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-emerald-500/5 border border-emerald-500/10 text-center">
                         <p class="text-2xl font-black italic text-emerald-500 pb-1">-15%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">Return Rate Reduction</p>
                      </div>
                   </div>
                   <div class="p-6 bg-accent/5 rounded-3xl border border-accent/10">
                      <h4 class="text-lg font-bold mb-3 flex items-center gap-2"><Icon name="lucide:activity" class="w-5 h-5 text-accent" /> Technical Highlights</h4>
                      <p class="text-xs text-muted leading-relaxed">Local deployment of 7B small model, stable operation even in offline environment. Personalized recommendation algorithms improve conversion rates, intelligent ticket classification improves processing efficiency. Support private deployment to ensure business privacy.</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right lg:order-1 relative">
                <img src="https://images.unsplash.com/photo-1556742393-d75f468bfcb0?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 3: Government -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
             <div class="animate-on-scroll animate-left">
                <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 inline-block">GOVERNMENT · 政务服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">Government Services Intelligent Assistant</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-primary uppercase mb-3 text-primary/60">Project Background & Pain Points</p>
                      <p class="text-sm text-muted leading-relaxed">
                        Demand: Improve government efficiency, achieve intelligent consultation. Pain points: Frequent policy updates, low answer efficiency and large consultation volume. Goal: Build a secure and reliable policy intelligent service system.
                      </p>
                   </div>
                   <div class="bento-card p-10 bg-primary/5 hover:border-primary/50 transition-all group">
                      <h4 class="text-xl font-black mb-4 italic tracking-tight flex items-center gap-2">
                        <Icon name="lucide:landmark" class="w-6 h-6 text-primary" />
                        Solution
                      </h4>
                      <p class="text-sm text-muted leading-relaxed mb-6 italic border-l-4 border-primary pl-6">
                        Based on 3B local model to ensure data security. Achieve real-time government knowledge base updates, deep multi-department business collaboration, intelligent appointment reminders, and precise policy push.
                      </p>
                      <div class="flex items-center gap-10">
                        <div>
                          <p class="text-2xl font-black italic text-primary">98%</p>
                          <p class="text-[10px] uppercase font-bold opacity-50">Citizen Satisfaction</p>
                        </div>
                        <div>
                          <p class="text-2xl font-black italic text-primary">200%</p>
                          <p class="text-[10px] uppercase font-bold opacity-50">Efficiency Improvement</p>
                        </div>
                      </div>
                   </div>
                   <div class="p-6 border-l-2 border-primary/20">
                      <h4 class="text-lg font-bold mb-3">Security Features</h4>
                      <p class="text-xs text-muted leading-relaxed">Adopt full local deployment to ensure government sensitive data security. Support physically isolated operation, stable and reliable. Independent deployment for each department, data independent and non-interfering, extremely controllable costs.</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right relative">
                <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 4: Power Grid -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center flex-row-reverse">
             <div class="animate-on-scroll animate-left lg:order-2">
                <span class="text-orange-500 text-xs font-bold uppercase tracking-widest mb-4 inline-block">ENERGY · 电力能源</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">State Grid Intelligent Service Platform</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-orange-500 uppercase mb-3 text-orange-500/60">Project Background & Pain Points</p>
                      <p class="text-sm text-muted leading-relaxed">
                        Demand: Improve response speed, solve user consultation pressure. Pain points: 24-hour service demand and emergency incident pressure. Goal: Build a secure, highly available power service intelligent platform.
                      </p>
                   </div>
                   <div class="p-10 rounded-[3rem] bg-slate-900 text-white border-none group overflow-hidden relative">
                      <div class="absolute inset-0 bg-orange-500/5 group-hover:bg-orange-500/10 transition-colors"></div>
                      <div class="relative z-10">
                        <h4 class="text-xl font-black mb-6 italic tracking-tight">Solution</h4>
                        <ul class="space-y-4 text-sm text-white/70 italic list-none">
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> Deploy 3B local model to ensure grid data security</li>
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> Power fault automatic diagnosis and intelligent bill resolution</li>
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> Emergency incident response and intelligent ticket allocation</li>
                        </ul>
                      </div>
                   </div>
                   <div class="grid grid-cols-3 gap-6">
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">70%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">Response Time Reduction</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">55%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">O&M Cost Reduction</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">99.9%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">System Availability</p>
                      </div>
                   </div>
                   <div class="p-6 border-r-2 border-orange-500/20 text-right">
                      <h4 class="text-lg font-bold mb-3 flex items-center justify-end gap-2">Core Capabilities <Icon name="lucide:zap" class="w-5 h-5 text-orange-500" /></h4>
                      <p class="text-xs text-muted leading-relaxed">Intelligent system specifically designed for the power industry, supporting noisy dialect recognition and professional power terminology processing, ensuring precise power service output in extreme environments.</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right lg:order-1 relative">
                <img src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>
    </section>

    <!-- Transition Impact: Results Dashboard -->
    <section class="py-32 px-6 max-w-7xl mx-auto border-t border-border-light dark:border-primary/20">
      <div class="text-center mb-20 animate-on-scroll">
         <h2 class="text-4xl md:text-6xl font-black tracking-tighter italic mb-4">Transformation Impact Statistics</h2>
         <p class="text-xl text-muted font-medium">Enterprise digital transformation results overview</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((s, i) => (
          <div class="animate-on-scroll p-12 rounded-[3.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20 text-center group hover:scale-[1.02] transition-all" style={`transition-delay: ${i * 100}ms`}>
            <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mx-auto mb-10 group-hover:bg-primary group-hover:text-white transition-all">
               <Icon name={s.icon} class="w-8 h-8" />
            </div>
            <p class="text-5xl font-black italic tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-primary to-accent mb-4">{s.value}</p>
            <h4 class="text-xl font-bold mb-2 italic tracking-tight">{s.title}</h4>
            <p class="text-xs text-muted font-medium tracking-wide uppercase">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6">
       <div class="animate-on-scroll bento-card max-w-5xl mx-auto text-center border-none bg-gradient-to-br from-[#0B123B] to-primary text-white p-16 md:p-24 shadow-2xl relative overflow-hidden">
           <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/enterprise/1920/1080?blur=10')] opacity-10 mix-blend-overlay"></div>
           <div class="relative z-10">
              <h2 class="text-4xl md:text-7xl font-black italic tracking-tighter mb-8">Start Enterprise Digital Transformation</h2>
              <p class="text-xl text-white/80 mb-12 font-medium max-w-3xl mx-auto text-center">Professional digital transformation team, tailor-making exclusive solutions for you. From strategy to delivery, we walk alongside you.</p>
              <div class="flex flex-wrap justify-center gap-6">
                <a href="/en/contact/" class="px-12 py-5 bg-white text-primary font-black italic rounded-full hover:scale-105 transition-all shadow-xl">Contact Transformation Consultant</a>
              </div>
           </div>
       </div>
    </section>
  </main>
</Layout>