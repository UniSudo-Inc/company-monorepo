---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';
import { getHomePermalinkEn } from '@/utils/permalinks';

const metadata = {
  title: 'Industry Solutions - UniSudo',
};

const stats = [
  { title: 'Cost Advantage', value: '75%', desc: 'Local deployment average cost savings', icon: 'lucide:coins' },
  { title: 'Data Security', value: '100%', desc: 'Data localization fully controllable', icon: 'lucide:shield-check' },
  { title: 'Performance Guarantee', value: '0.5s', desc: 'Millisecond response, 99.99% availability', icon: 'lucide:zap' },
  { title: 'Effect Enhancement', value: '60%', desc: 'Average business efficiency improvement', icon: 'lucide:trending-up' }
];

const solutions = [
  {
    tagline: 'Solution 01 · Education',
    title: 'Education & Training Digital Transformation',
    image: 'https://images.unsplash.com/photo-1523580494863-6f3031224c94?q=80&w=1740&auto=format&fit=crop',
    color: 'primary',
    points: [
      { label: 'Industry Pain Points', text: 'Difficult to meet personalized teaching needs, teaching quality assessment difficulties, insufficient learning outcome tracking, uneven distribution of quality educational resources.' },
      { label: 'Solution', text: 'Deploy 3B local models to build intelligent teaching systems. Provide personalized learning path planning, AI tutor Q&A, intelligent homework grading, and learning analytics early warning.' },
      { label: 'Implementation Effect', text: 'Learning efficiency improved by 40%, teacher workload reduced by 60%, system response time <0.5s.' }
    ],
    highlight: 'Technical Highlights',
    highlightText: 'Based on local small model deployment to ensure student data security. Supports offline operation, single machine can support thousands of concurrent users, extremely high cost performance.'
  },
  {
    tagline: 'Solution 02 · Healthcare',
    title: 'Medical Health Intelligent Diagnosis',
    image: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?q=80&w=1740&auto=format&fit=crop',
    color: 'emerald-500',
    isReversed: true,
    points: [
      { label: 'Industry Pain Points', text: 'Shortage of quality medical resources, need to improve diagnosis efficiency, doctor-patient communication needs improvement, difficulty in chronic disease management.' },
      { label: 'Solution', text: 'Deploy 7B local models to ensure privacy. Integrate intelligent pre-consultation, diagnostic decision support, intelligent follow-up, and medical knowledge graph.' },
      { label: 'Implementation Effect', text: 'Diagnosis efficiency improved by 50%, satisfaction improved by 60%, diagnostic accuracy rate 95%.' }
    ],
    highlight: 'Privacy Protection',
    highlightText: 'Adopt local deployment mode, medical data never leaves the hospital. Supports multi-hospital collaboration, meeting level III hospital data security compliance requirements.'
  },
  {
    tagline: 'Solution 03 · Financial Risk Control',
    title: 'Financial Risk Control Intelligent Analysis',
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?q=80&w=1740&auto=format&fit=crop',
    color: 'indigo-500',
    points: [
      { label: 'Industry Pain Points', text: 'Poor real-time risk identification, rapidly evolving fraudulent methods, high manual audit costs, increasingly strict compliance requirements.' },
      { label: 'Solution', text: 'Deploy 3B local models to ensure compliance. Provide real-time risk warning, intelligent anti-fraud engine, automated audit process.' },
      { label: 'Implementation Effect', text: 'Risk identification rate improved by 70%, manual cost reduced by 65%, system availability 99.99%.' }
    ],
    highlight: 'Security Compliance',
    highlightText: 'Local deployment ensures financial core data security. Millisecond response meets real-time risk control needs, cost as low as one-tenth of cloud services.'
  },
  {
    tagline: 'Solution 04 · Retail',
    title: 'Retail Intelligent Upgrade',
    image: 'https://images.unsplash.com/photo-1563986768494-4dee2763ff3f?q=80&w=1740&auto=format&fit=crop',
    color: 'accent',
    isReversed: true,
    points: [
      { label: 'Industry Pain Points', text: 'Low inventory management efficiency, difficulty in personalized marketing, need to improve customer experience, high operating costs.' },
      { label: 'Solution', text: 'Deploy 7B local models to protect customer data. Achieve intelligent replenishment prediction, personalized recommendation engine, and omnichannel customer service.' },
      { label: 'Implementation Effect', text: 'Inventory turnover improved by 40%, marketing conversion improved by 55%, ROI improved by 200%.' }
    ],
    highlight: 'Cost Advantage',
    highlightText: 'Local deployment mode significantly reduces operating costs. Single store deployment can serve the entire region, scenario adaptability far exceeds standard cloud services.'
  },
  {
    tagline: 'Solution 05 · Smart City',
    title: 'Smart City Data Platform',
    image: 'https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?q=80&w=1740&auto=format&fit=crop',
    color: 'blue-500',
    points: [
      { label: 'Industry Pain Points', text: 'Severe data silos, difficulty in cross-department collaboration, low service efficiency, insufficient large-scale decision support.' },
      { label: 'Solution', text: 'Deploy 3B local models to ensure data security. Cover city data intelligent analysis, cross-department business collaboration, and integrated citizen services.' },
      { label: 'Implementation Effect', text: 'Collaboration efficiency improved by 80%, response time reduced by 70%, monthly operating cost reduced by approximately 85%.' }
    ],
    highlight: 'Data Security',
    highlightText: 'Local deployment ensures government sensitive data security level. Supports high-frequency cross-department collaboration while implementing strict permission control.'
  },
  {
    tagline: 'Solution 06 · Tourism & Culture',
    title: 'Tourism & Culture Industry Digital Services',
    image: 'https://images.unsplash.com/photo-1569949381669-ecf31ae8e613?q=80&w=1740&auto=format&fit=crop',
    color: 'orange-500',
    isReversed: true,
    points: [
      { label: 'Industry Pain Points', text: 'Visitor experience to be improved, low scenic spot management efficiency, single marketing approach, inefficient public resource utilization.' },
      { label: 'Solution', text: 'Deploy 7B local models to build smart scenic spots. Integrate intelligent tour guide narration, passenger flow prediction, personalized itinerary recommendation.' },
      { label: 'Implementation Effect', text: 'Visitor stay increased by 45%, scenic spot revenue increased by 50%, operating cost reduced by 40%.' }
    ],
    highlight: 'Scenario Innovation',
    highlightText: 'Local offline operation, can provide smooth services even in scenic areas with unstable network. Single server carries entire scenic area business.'
  }
];
---

<Layout metadata={metadata}>
  <main class="relative z-10 pt-0 text-balance">
    <!-- Dynamic Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="absolute top-[-10%] right-[-10%] w-[60%] h-[60%] bg-blue-500/5 rounded-full blur-[150px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] left-[-10%] w-[50%] h-[50%] bg-purple-500/5 rounded-full blur-[150px] animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <!-- Hero Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center animate-on-scroll">
      <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
        INDUSTRIES · 行业方案
      </span>
      <h1 class="text-6xl md:text-7xl font-black mb-8 tracking-tighter leading-[0.9] ">
        Multi-industry<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent text-5xl md:text-6xl italic">Scenario-based Solutions</span>
      </h1>
      <p class="text-xl text-muted max-w-3xl mx-auto font-medium leading-relaxed">
        Local Deployment · User-friendly Interaction · Data Security. For in-depth scenarios in different vertical fields, through lightweight AI technology empowerment, achieve rapid transformation from pain points to value.
      </p>
    </section>

    <!-- Detailed Solutions -->
    <section class="space-y-40 py-20">
      {solutions.map((sol) => (
        <div class="px-6 max-w-7xl mx-auto">
          <div class={`grid grid-cols-1 lg:grid-cols-2 gap-16 items-center ${sol.isReversed ? 'lg:flex-row-reverse' : ''}`}>
             <div class={`animate-on-scroll ${sol.isReversed ? 'animate-right lg:order-2' : 'animate-left'}`}>
                <span class={`text-${sol.color || 'primary'} text-[10px] font-black uppercase tracking-widest mb-4 inline-block`}>{sol.tagline}</span>
                <h3 class="text-3xl md:text-5xl font-black mb-10 tracking-tighter italic">{sol.title}</h3>
                
                <div class="space-y-6 mb-10">
                   {sol.points.map(p => (
                     <div class="p-6 rounded-3xl bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20">
                       <p class={`text-[10px] font-black uppercase mb-2 text-${sol.color || 'primary'}`}>{p.label}</p>
                       <p class="text-sm text-muted leading-relaxed font-medium">{p.text}</p>
                     </div>
                   ))}
                </div>

                <div class={`p-8 rounded-[2.5rem] bg-${sol.color || 'primary'}/5 border border-${sol.color || 'primary'}/10 relative overflow-hidden group`}>
                   <div class="absolute -top-4 -right-4 opacity-10 group-hover:scale-125 transition-transform duration-700">
                      <Icon name="lucide:sparkles" class="w-16 h-16" />
                   </div>
                   <h4 class="text-xl font-black mb-4 italic tracking-tight">{sol.highlight}</h4>
                   <p class="text-sm text-muted leading-relaxed font-medium italic">{sol.highlightText}</p>
                </div>
             </div>
             
             <div class={`animate-on-scroll ${sol.isReversed ? 'animate-left lg:order-1' : 'animate-right'}`}>
                <div class="rounded-[4rem] overflow-hidden shadow-2xl relative group">
                   <img src={sol.image} alt={sol.title} class="w-full aspect-square object-cover transition-transform duration-700 group-hover:scale-105" referrerpolicy="no-referrer" />
                   <div class="absolute inset-0 bg-gradient-to-t from-slate-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
                </div>
             </div>
          </div>
        </div>
      ))}
    </section>

    <!-- Overall Results -->
    <section class="py-32 px-6 max-w-7xl mx-auto rounded-[5rem] bg-slate-900 text-white relative overflow-hidden">
      <div class="absolute inset-0 bg-primary/10 blur-[100px] -z-10 animate-pulse"></div>
      <div class="text-center mb-20 animate-on-scroll">
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter italic">Overall Value of Industry Solutions</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((s, i) => (
          <div class="animate-on-scroll p-12 rounded-[3.5rem] bg-white/5 border border-white/10 text-center flex flex-col items-center group hover:bg-white/10 transition-all" style={`transition-delay: ${i * 50}ms`}>
            <div class="w-14 h-14 bg-primary/20 rounded-2xl flex items-center justify-center text-primary mb-8 group-hover:scale-110 transition-transform">
               <Icon name={s.icon} class="w-6 h-6" />
            </div>
            <p class="text-5xl font-black italic tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-primary to-accent mb-4">{s.value}</p>
            <h4 class="text-lg font-bold mb-2 italic tracking-tight">{s.title}</h4>
            <p class="text-[10px] text-white/40 leading-relaxed font-medium uppercase tracking-widest">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6">
       <div class="animate-on-scroll bento-card max-w-5xl mx-auto text-center border-none bg-gradient-to-br from-primary via-accent to-purple-600 text-white p-16 md:p-24 shadow-2xl relative overflow-hidden">
           <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/industry/1920/1080?blur=10')] opacity-10 mix-blend-overlay"></div>
           <div class="relative z-10">
              <h2 class="text-4xl md:text-7xl font-black italic tracking-tighter mb-8">Start Your Industry Digital Transformation Journey</h2>
              <p class="text-xl text-white/80 mb-12 font-medium max-w-2xl mx-auto">Local deployment, secure and reliable, lower cost. Let us provide you with more competitive industry digital intelligence services.</p>
              <div class="flex flex-wrap justify-center gap-6">
                <a href="/en/contact/" class="px-12 py-5 bg-white text-primary font-black italic rounded-full hover:scale-105 transition-all shadow-xl">Book Expert Consultation</a>
                <a class="px-12 py-5 bg-white/10 backdrop-blur-md text-white border border-white/20 font-black italic rounded-full hover:bg-white/20 transition-all" rel='noopener noreferrer' href={getHomePermalinkEn()}>Learn More</a>
              </div>
           </div>
       </div>
    </section>
  </main>
</Layout>