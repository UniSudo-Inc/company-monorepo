---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: 'Development Roadmap - UniSudo Inc.',
};

const roadmapData = [
  {
    year: '2024',
    theme: 'Technology Foundation',
    color: 'from-violet-600 to-indigo-600',
    events: [
      {
        quarter: 'Q1 Innovation Takes Off',
        items: [
          'March, founding members of UniSudo Inc. collaborated to innovate the framework',
          'Completed theoretical breakthrough in streaming interruptible dialogue system, achieving 50x real-time rate',
          'Released first technical verification prototype to verify technology feasibility'
        ],
        side: 'left',
        icon: 'lucide:rocket'
      },
      {
        quarter: 'Q2-Q3 Core Technology Breakthrough',
        items: [
          'Completed TTS core technology R&D, achieving key performance indicators',
          'Built cloud-native platform framework, completed basic architecture deployment',
          'Conducted core algorithm optimization, established technical barriers'
        ],
        side: 'right',
        icon: 'lucide:brain'
      },
      {
        quarter: 'Q4 Product Matrix Takes Off',
        items: [
          'Released streaming interruptible dialogue system 1.0 version',
          'Launched first-generation smart hardware solutions',
          'Completed basic version development of AI workflow platform',
          'Started development of data annotation platform and AI analysis platform'
        ],
        side: 'left',
        icon: 'lucide:layout-grid'
      }
    ]
  },
  {
    year: '2025',
    theme: 'Deep Industry Applications',
    color: 'from-fuchsia-600 to-purple-600',
    events: [
      {
        quarter: 'H1 Vertical Field Breakthrough',
        items: [
          'Launched digital employee solution for manufacturing industry',
          'Completed autonomous driving scene data processing platform',
          'Released enterprise-level knowledge base intelligent Q&A system'
        ],
        side: 'right',
        icon: 'lucide:target'
      },
      {
        quarter: 'H2 Technology Upgrade & Scenario Expansion',
        items: [
          'Optimized small model training framework, reducing 50% computing resource consumption',
          'Expanded into new fields such as low-altitude flight and smart grids',
          'Established product ecosystem linkage mechanism'
        ],
        side: 'left',
        icon: 'lucide:zap'
      }
    ]
  },
  {
    year: '2026',
    theme: 'Scale Commercialization',
    color: 'from-blue-600 to-cyan-600',
    events: [
      {
        quarter: 'H1 Product Maturity & Market Expansion',
        items: [
          'Released 2.0 version of all product lines',
          'Built industry benchmark cases',
          'Established channel cooperation system'
        ],
        side: 'right',
        icon: 'lucide:shield-check'
      },
      {
        quarter: 'H2 Technology Innovation & Business Breakthrough',
        items: [
          'Released revolutionary lightweight AI engine',
          'Achieved scale commercialization',
          'Explored consumer-level product layout'
        ],
        side: 'left',
        icon: 'lucide:globe'
      }
    ]
  }
];

const milestones = [
  {
    title: 'Technology Innovation',
    desc: 'Innovation framework breakthrough, establishing technical barriers; lightweight AI engine R&D success; multi-scenario adaptation capability realized.',
    icon: 'lucide:lightbulb',
    color: 'bg-yellow-500/10 text-yellow-500'
  },
  {
    title: 'Product System',
    desc: 'Completed "5+X" product matrix construction; established product collaboration ecosystem; achieved scenario-level deep applications.',
    icon: 'lucide:layers',
    color: 'bg-blue-500/10 text-blue-500'
  },
  {
    title: 'Business Development',
    desc: 'Established technology-driven business model; built benchmark solutions; constructed complete business ecosystem.',
    icon: 'lucide:trending-up',
    color: 'bg-emerald-500/10 text-emerald-500'
  }
];
---

<Layout metadata={metadata}>
  <main class="relative z-10 pt-0">
    <!-- Dynamic Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>
    
    <!-- Hero Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center">
      <div class="animate-on-scroll">
        <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
          ROADMAP · Development Roadmap 
        </span>
        <br />
        <Fragment slot='title'>
          <span class="text-5xl md:text-6xl dark:text-white/80 text-black/80 tracking-tighter italic">UniSudo Inc. </span>
          <span class='text-5xl md:text-6xl animate-pulse text-primary dark:text-primary font-black tracking-tighter italic'>Development Blueprint</span>
        </Fragment>
        <p class="text-xl mt-6 text-muted max-w-2xl mx-auto font-medium leading-relaxed">
          From technological innovation to commercialization, we have mapped out a clear development path, aiming to become an innovator in AI infrastructure.
        </p>
      </div>
    </section>

    <!-- Interactive Timeline -->
    <section class="py-20 px-6 relative max-w-7xl mx-auto overflow-hidden">
      <!-- Center Line -->
      <div class="absolute left-1/2 top-0 bottom-0 w-px bg-gradient-to-b from-transparent via-gray-200 dark:via-gray-800 to-transparent lg:block"></div>

      {roadmapData.map((yearSection) => (
        <div class="mb-32 relative">
          <!-- Year Marker -->
          <div class="flex justify-center mb-20 animate-on-scroll">
            <div class={`px-8 py-3 rounded-full bg-gradient-to-r ${yearSection.color} text-white shadow-xl shadow-primary/20 transform -rotate-2`}>
              <span class="text-3xl font-black italic tracking-tighter">{yearSection.year}</span>
              <span class="ml-4 text-sm font-bold opacity-80 uppercase tracking-widest">{yearSection.theme}</span>
            </div>
          </div>

          <!-- Events -->
          <div class="space-y-24">
            {yearSection.events.map((event) => (
              <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                {/* Connector Dot (Desktop) */}
                <div class="absolute left-1/2 -translate-x-1/2 w-4 h-4 rounded-full bg-white dark:bg-[#030620] border-4 border-primary z-10 hidden lg:block"></div>

                <div class={`${event.side === 'right' ? 'lg:order-2' : ''} animate-on-scroll ${event.side === 'right' ? 'animate-right' : 'animate-left'}`}>
                  <div class="bento-card relative group overflow-hidden">
                    <div class="absolute top-0 right-0 p-8 opacity-5 group-hover:opacity-10 transition-opacity">
                       <Icon name={event.icon} class="w-32 h-32" />
                    </div>
                    <div class="relative z-10">
                      <div class="flex items-center gap-4 mb-6">
                        <div class="w-10 h-10 rounded-xl bg-primary/10 flex items-center justify-center text-primary">
                          <Icon name={event.icon} class="w-5 h-5" />
                        </div>
                        <h3 class="text-2xl font-black italic tracking-tighter">{event.quarter}</h3>
                      </div>
                      <ul class="space-y-4">
                        {event.items.map(item => (
                          <li class="flex gap-3 text-sm text-muted group/li transition-colors hover:text-black dark:hover:text-white">
                            <span class="text-primary mt-1 font-black">/</span>
                            <span>{item}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  </div>
                </div>

                {/* Empty spacer for alignment */}
                <div class="hidden lg:block"></div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </section>

    <!-- Core Milestones -->
    <section class="py-32 px-6 max-w-7xl mx-auto bg-surface-light dark:bg-surface-dark/30 rounded-[4rem] border border-gray-200 dark:border-gray-800 mb-32 relative overflow-hidden">
      <div class="absolute inset-0 bg-primary/5 -z-10 blur-[100px]"></div>
      <div class="animate-on-scroll text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-black tracking-tighter italic mb-4">Core Milestones</h2>
        <p class="text-muted text-lg max-w-2xl mx-auto font-medium">Comprehensive breakthroughs in three dimensions, building a closed loop of technology and business.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {milestones.map((m, i) => (
          <div class="animate-on-scroll bento-card border-none bg-white/50 dark:bg-white/5" style={`transition-delay: ${i * 100}ms`}>
            <div class={`w-14 h-14 rounded-2xl ${m.color} flex items-center justify-center mb-8`}>
              <Icon name={m.icon} class="w-7 h-7" />
            </div>
            <h3 class="text-2xl font-black italic tracking-tight mb-4">{m.title}</h3>
            <p class="text-sm text-muted leading-relaxed whitespace-pre-line">{m.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Future Vision -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center border-t border-gray-200 dark:border-gray-800">
      <div class="animate-on-scroll mb-16">
        <h2 class="text-5xl md:text-7xl font-black tracking-tighter italic mb-8">Future Prospects</h2>
        <p class="text-xl text-muted max-w-3xl mx-auto font-medium leading-relaxed">
          From the spark of innovative ideas to the breakthrough of core technologies, and to the construction of a complete product system, UniSudo Inc. has always adhered to technological innovation as the core driving force. We will continue to deepen our expertise in vertical scenarios and use innovative technology to empower traditional industries, truly serving industrial upgrading.
        </p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {[
          { title: 'AI Infrastructure Innovator', icon: 'lucide:lightbulb' },
          { title: 'Scenario-level AI Application Leader', icon: 'lucide:layers' },
          { title: 'Promote AI Technology Accessibility', icon: 'lucide:heart-handshake' },
          { title: 'Build Open Technical Ecosystem', icon: 'lucide:code' }
        ].map((item, i) => (
          <div class="animate-on-scroll p-8 rounded-3xl border border-gray-200 dark:border-gray-800 hover:border-primary transition-colors group" style={`transition-delay: ${i * 50}ms`}>
            <Icon name={item.icon} class="w-8 h-8 text-primary mx-auto mb-4 group-hover:scale-110 transition-transform" />
            <span class="text-sm font-bold tracking-tight">{item.title}</span>
          </div>
        ))}
      </div>
    </section>
  </main>

</Layout>

<style>
  .animate-left { transform: translateX(-40px); opacity: 0; }
  .animate-right { transform: translateX(40px); opacity: 0; }
  .animate-on-scroll { transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1); }
  
  :global(.animate-on-scroll.is-visible) {
    transform: translate(0, 0);
    opacity: 1;
  }
</style>