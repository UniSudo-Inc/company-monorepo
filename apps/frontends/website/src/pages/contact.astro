---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';
import ContactUs from '@/components/widgets/Contact.astro';

const metadata = {
  title: '联系我们',
};
---

<Layout metadata={metadata}>
  <div class='relative'>
    
    <div class='relative mx-auto max-w-7xl px-4 py-20 sm:px-6'>
      <div class='text-center'>
        <p class='mb-3 text-base font-bold uppercase tracking-[0.2em] text-accent'>联系我们</p>
        <h1 class='mb-6 text-4xl font-bold tracking-tight text-default dark:text-white md:text-5xl'>
          <span class='text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent'>期待与您沟通！</span>
        </h1>
        
        <div class='relative mx-auto mb-12 mt-4 inline-flex'>
          <span class='absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-20'></span>
          <span class='relative inline-flex h-20 w-20 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent shadow-lg shadow-primary/30'>
            <Icon name='tabler:messages' class='h-10 w-10 text-white' />
          </span>
        </div>
      </div>
    </div>
  </div>

  <div class='relative mx-auto max-w-7xl px-4 py-0 sm:px-6'>
    <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento mx-auto max-w-3xl p-0'>
      <ContactUs
        id='form'
        title='商务合作咨询'
        subtitle='请填写以下信息，我们会尽快与您联系'
        inputs={[
          {
            type: 'text',
            name: 'name',
            label: '您的姓名',
            placeholder: '请输入您的姓名'
          },
          {
            type: 'text',
            name: 'company',
            label: '公司名称',
            placeholder: '请输入您的公司名称'
          },
          {
            type: 'tel',
            name: 'phone',
            label: '手机号码',
            placeholder: '请输入您的手机号码'
          },
          {
            type: 'email',
            name: 'email',
            label: '电子邮箱',
            placeholder: 'you@example.com'
          }
        ]}
        textarea={{
          name: 'message',
          label: '您的需求或合作意向',
          placeholder: '请在此处详细描述您的需求...'
        }}
        button='提交信息'
      >
        <Fragment slot='bg'>
          <div
            id='snackbar-toast'
            class='toast absolute bottom-6 right-12 z-10 rounded-xl border border-hairline bg-surface p-4 shadow-xl dark:bg-surface'
            hidden
          >
          </div>
        </Fragment>
      </ContactUs>
    </div>
  </div>

  <div class='relative'>
    
    <div class='relative mx-auto max-w-7xl px-4 py-16 sm:px-6'>
      <div class='mb-12 text-center'>
        <p class='mb-3 text-base font-bold uppercase tracking-[0.2em] text-accent'>服务支持</p>
        <h2 class='text-3xl font-bold tracking-tight text-default dark:text-white'>我们随时为您服务！</h2>
      </div>
      <div class='grid grid-cols-1 gap-6 md:grid-cols-3'>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8' style='animation-delay: 0ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10'>
            <Icon name='tabler:briefcase' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>商务合作</h3>
          <p class='text-muted leading-relaxed'>如果您对我们的产品和服务感兴趣，期待与您探讨合作机会，为您的企业提供最适合的AI解决方案。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8' style='animation-delay: 100ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10'>
            <Icon name='tabler:headset' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>技术支持</h3>
          <p class='text-muted leading-relaxed'>我们的技术团队为您提供专业的技术支持，解决您在使用过程中遇到的问题，确保系统稳定运行。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8' style='animation-delay: 200ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10'>
            <Icon name='tabler:shield-check' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>售后服务</h3>
          <p class='text-muted leading-relaxed'>我们提供完善的售后服务体系，确保您的需求得到及时响应和解决，为您的业务保驾护航。</p>
        </div>
      </div>
    </div>
  </div>

  <div class='relative pb-20'>
    <div class='mx-auto max-w-7xl px-4 sm:px-6'>
      <div class='grid grid-cols-1 gap-6 md:grid-cols-3'>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8 text-center' style='animation-delay: 0ms'>
          <Icon name='tabler:phone' class='mx-auto mb-4 h-8 w-8 text-primary' />
          <h3 class='mb-2 text-lg font-bold tracking-tight text-default dark:text-white'>联系电话</h3>
          <p class='text-muted'>16628597963</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8 text-center' style='animation-delay: 100ms'>
          <Icon name='tabler:mail' class='mx-auto mb-4 h-8 w-8 text-primary' />
          <h3 class='mb-2 text-lg font-bold tracking-tight text-default dark:text-white'>电子邮箱</h3>
          <a href='mailto:contact@unisudo.com' class='text-muted hover:text-primary transition-colors'>contact@unisudo.com</a>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento p-8 text-center' style='animation-delay: 200ms'>
          <Icon name='tabler:map-pin' class='mx-auto mb-4 h-8 w-8 text-primary' />
          <h3 class='mb-2 text-lg font-bold tracking-tight text-default dark:text-white'>公司地址</h3>
          <p class='text-muted text-sm'>上海市浦东新区临港自贸区水芸路55号港城广场二街坊1号楼8层802室</p>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  function toast(message: string) {
    const toastElem = document.getElementById('snackbar-toast');
    if (!toastElem) {
      console.error('Could not find the toast element');
      return;
    }
    toastElem.innerText = message;
    toastElem.hidden = false;
    setTimeout(() => {
      toastElem.hidden = true;
      toastElem.innerText = '';
    }, 3000);
  }

  const form = document.querySelector('#form form');
  const button = form?.querySelector('button[type="submit"]');

  if (!form || !button) {
    console.error('Could not find the contact form or submit button');
  } else {
    const originalButtonHTML = button.innerHTML;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      button.setAttribute('disabled', '');
      button.innerHTML = `
        <svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-white inline" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        正在提交...
      `;

      const formData = new FormData(form as HTMLFormElement);
      const formProps = Object.fromEntries(formData);

      const payload = {
        name: formProps["name"],
        email: formProps["email"],
        phone: formProps["phone"],
        company: formProps["company"],
        message: formProps["message"],
        subject: '商务合作咨询',
        source: '官网合作页面'
      };

      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const supabaseAnonKey = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      if (!supabaseUrl || !supabaseAnonKey) {
        console.error('Supabase URL or Anon Key is not defined in environment variables.');
        toast('客户端配置错误');
        button.removeAttribute('disabled');
        button.innerHTML = originalButtonHTML;
        return;
      }

      try {
        const response = await fetch(`${supabaseUrl}/functions/v1/sendmail`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${supabaseAnonKey}`,
          },
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          const data = await response.json();
          toast(data.message || '发送成功！我们尽快与您联系。');
          (form as HTMLFormElement).reset();
          button.removeAttribute('disabled');
          button.innerHTML = originalButtonHTML;
        } else {
          const errorData = await response.json().catch(() => null);
          toast(`提交失败: ${errorData?.message || '请稍后重试'}`);
          button.removeAttribute('disabled');
          button.innerHTML = originalButtonHTML;
        }
      } catch (error) {
        console.error('Form submission error:', error);
        toast('提交失败，请检查您的网络连接。');
        button.removeAttribute('disabled');
        button.innerHTML = originalButtonHTML;
      }
    });
  }
</script>