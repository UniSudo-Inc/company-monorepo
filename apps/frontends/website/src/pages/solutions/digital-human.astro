---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';
import Hero from '@/components/widgets/Hero.astro';
import Content from '@/components/widgets/Content.astro';
import CallToAction from '@/components/widgets/CallToAction.astro';
import Timeline from '@/components/widgets/Timeline.astro';
import speechAI from '@/assets/images/speechAI.png';
import daoGou from '@/assets/images/daogou.png';

const metadata = {
  title: '数字人展厅解决方案',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline='数字人展厅'
    image={{
      src: 'https://images.unsplash.com/photo-1599727277707-b429a4994c15?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'AI数据处理',
    }}
  >
    <Fragment slot='title'>
      <span class='text-4xl md:text-5xl font-bold tracking-tight leading-tight'>数据赋能 智创未来</span><br />
      <span class='text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent text-2xl md:text-3xl mt-3 font-semibold'>专业的AI数据服务解决方案</span>
    </Fragment>

    <Fragment slot='subtitle'>
      <span class='text-lg md:text-xl text-muted leading-relaxed max-w-3xl mx-auto'>
        从数据标注到隐私保护，提供全方位的AI数据处理服务，助力您的AI项目成功落地
      </span>
    </Fragment>
  </Hero>

  <div class='relative'>
    
    <div class='relative mx-auto max-w-7xl px-4 py-20 sm:px-6'>
      <div class='mb-16 text-center'>
        <p class='mb-3 text-base font-bold uppercase tracking-[0.2em] text-accent'>应用场景</p>
        <h2 class='text-4xl font-bold tracking-tight text-default dark:text-white md:text-5xl'>多领域数字人解决方案</h2>
      </div>
      <div class='grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3'>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 0ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:building-bank' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>银行智能网点</h3>
          <p class='text-muted leading-relaxed'>24/7全天候服务的智能网点数字员工，提升服务效率，降低人力成本。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 100ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:building' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>博物馆虚拟讲解</h3>
          <p class='text-muted leading-relaxed'>沉浸式智能讲解体验，支持多语种讲解，个性化参观路线规划。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 200ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:shopping-cart' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>企业展厅导购</h3>
          <p class='text-muted leading-relaxed'>3D产品配置展示，智能报价与方案定制，提升客户驻留时间。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 300ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:shopping-cart' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>商场数字导购</h3>
          <p class='text-muted leading-relaxed'>商场导航系统，实时优惠推送，个性化购物建议，提升客单价。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 400ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:book' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>教育培训讲师</h3>
          <p class='text-muted leading-relaxed'>AI外教系统，智能学习评估，实时口语互动，提升学习效果。</p>
        </div>
        <div class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento group cursor-pointer' style='animation-delay: 500ms'>
          <div class='mb-5 flex h-14 w-14 items-center justify-center rounded-2xl bg-gradient-to-br from-primary/10 to-accent/10 transition-all duration-300 group-hover:scale-110 group-hover:from-primary/20 group-hover:to-accent/20'>
            <Icon name='tabler:star' class='h-7 w-7 text-primary' />
          </div>
          <h3 class='mb-3 text-xl font-bold tracking-tight text-default dark:text-white'>品牌数字代言人</h3>
          <p class='text-muted leading-relaxed'>直播互动系统，社交媒体互动，提升品牌好感度和市场认知度。</p>
        </div>
      </div>
    </div>
  </div>

  <Content
    isReversed
    tagline='案例研究'
    title='银行智能网点数字员工'
    items={[
      {
        title: '项目背景',
        description: '需求：提升网点服务效率，降低人力成本。痛点：非工作时间无法服务、高峰期等待时间长、人工成本高。目标：打造24/7全天候服务的智能网点。',
      },
      {
        title: '解决方案',
        description: '部署智能数字员工，集成核心业务系统，提供多语言服务能力，实现业务咨询、产品推荐、办理指导等功能。',
      },
      {
        title: '实施效果',
        description: '客户等待时间减少60%，业务处理效率提升40%，客户满意度提升25%，年节省运营成本约200万元。',
      }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1579621970563-ebec7560ff3e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '银行数字员工',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>场景故事</h3>
      <p class='text-muted leading-relaxed'>某客户在深夜需要办理一笔紧急的国际汇款。传统银行网点已经下班，但智能网点数字员工24小时在线。数字员工不仅帮助客户完成了汇款预约，还贴心地提供了汇率咨询和手续费优惠方案，整个过程仅用时10分钟。</p>
    </Fragment>

    <Fragment slot='bg'>
      
    </Fragment>
  </Content>

  <Content
    isAfterContent
    tagline='案例研究'
    title='博物馆虚拟讲解员'
    items={[
      {
        title: '项目背景',
        description: '需求：提升文物展示体验，解决讲解员人手不足问题。痛点：优质讲解资源有限，个性化讲解需求难满足。目标：打造沉浸式智能讲解体验。',
      },
      {
        title: '解决方案',
        description: '部署虚拟讲解员，构建文物知识图谱，支持多语种讲解服务，提供个性化参观路线规划。',
      },
      {
        title: '实施效果',
        description: '日均服务游客增加300%，讲解满意度达95%，文物知识传播效果提升50%，运营成本降低40%。',
      }
    ]}
    image={{
      src: speechAI,
      alt: '博物馆讲解',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>场景故事</h3>
      <p class='text-muted leading-relaxed'>一个对历史特别感兴趣的小学生在参观博物馆时，虚拟讲解员不仅为他详细讲解了展品历史，还能根据他的兴趣互动问答，通过生动的故事和3D展示让历史知识变得生动有趣。家长表示，这比传统讲解更能激发孩子的学习兴趣。</p>
    </Fragment>

    <Fragment slot='bg'>
      
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent
    tagline='案例研究'
    title='企业展厅互动导购'
    items={[
      {
        title: '项目背景',
        description: '需求：提升展厅互动体验，实现智能化产品展示。痛点：专业展示人员成本高，服务标准不统一。目标：打造沉浸式智能展厅体验。',
      },
      {
        title: '解决方案',
        description: '部署AI导购助手，开发3D产品配置展示系统，实现智能报价与方案定制，提供虚拟体验服务。',
      },
      {
        title: '实施效果',
        description: '客户驻留时间增加45%，成交转化率提升35%，客户满意度达98%，人力成本降低50%。',
      }
    ]}
    image={{
      src: daoGou,
      alt: '展厅导购',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>场景故事</h3>
      <p class='text-muted leading-relaxed'>某位客户对新能源汽车产品感兴趣，通过数字导购的互动介绍，不仅了解了产品的详细配置，还通过AR技术实时体验了不同外观选择的效果。数字导购根据客户需求提供了个性化的配置建议和金融方案，最终帮助客户找到了最适合的选择。</p>
    </Fragment>

    <Fragment slot='bg'>
      
    </Fragment>
  </Content>

  <div class='relative'>
    
    <Timeline
      title='数字人解决方案整体效果'
      items={[
        {
          title: '服务效率提升',
          description: '平均提升服务效率40%，24/7全天候服务覆盖',
          icon: 'tabler:clock',
        },
        {
          title: '成本优化',
          description: '运营成本平均降低45%，人力资源优化配置',
          icon: 'tabler:coin',
        },
        {
          title: '用户满意度',
          description: '客户满意度提升35%，互动体验显著改善',
          icon: 'tabler:heart',
        },
        {
          title: '品牌价值',
          description: '品牌形象提升40%，市场认知度大幅提升',
          icon: 'tabler:star',
        },
      ]}
    />
  </div>

  <div class='relative'>
    
    <CallToAction
      title='开启您的数字化转型之旅'
      subtitle='让我们帮助您打造专属的数字人解决方案'
      actions={[
        {
          variant: 'primary',
          text: '预约演示',
          href: '/contact/',
          icon: 'tabler:calendar',
        },
        {
          text: '了解更多',
          href: '/about/',
        },
      ]}
    />
  </div>
</Layout>