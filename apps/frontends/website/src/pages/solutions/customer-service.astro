---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: '智能客服解决方案 - UniSudo 智独数科技',
};

const serviceFlow = [
  { title: '多渠道接入', desc: '支持网页、APP、小程序等多渠道统一接入', icon: 'lucide:smartphone' },
  { title: '智能理解', desc: '基于 3B/7B 小模型的自然语言理解能力', icon: 'lucide:brain' },
  { title: '知识匹配', desc: '精准匹配企业知识库，提供专业级解答', icon: 'lucide:database' },
  { title: '智能回复', desc: '自然流畅的对话响应，像真人一样交流', icon: 'lucide:message-circle' }
];

const advantages = [
  { title: '成本优势', desc: '本地部署 3B/7B 模型可节省 80% 运营成本', icon: 'lucide:coins' },
  { title: '数据安全', desc: '企业数据完全本地化，严防敏感信息泄露', icon: 'lucide:shield-check' },
  { title: '响应速度', desc: '本地部署响应 <100ms，较云端快 10 倍以上', icon: 'lucide:zap' },
  { title: '个性定制', desc: '针对特定深度场景微调，提供更精准服务', icon: 'lucide:settings' }
];
---

<Layout metadata={metadata}>
  <main class="relative z-10 pt-0">
    <!-- Dynamic Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <!-- Hero Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center animate-on-scroll">
      <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
        SOLUTIONS · 智能客服
      </span>
      <h1 class="text-6xl md:text-7xl font-black mb-8 tracking-tighter leading-[0.9]">
        智能客服<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent text-5xl md:text-6xl italic">智联业务核心</span>
      </h1>
      <p class="text-xl text-muted max-w-3xl mx-auto font-medium leading-relaxed">
        本地部署 · 成本可控 · 安全可靠。基于 3B/7B 小模型技术，打造更懂业务的私有化智能服务体系。
      </p>
    </section>

    <!-- Service Flow -->
    <section class="py-20 px-6 max-w-7xl mx-auto">
      <div class="text-center mb-20 animate-on-scroll">
        <p class="mb-3 text-base font-bold uppercase tracking-[0.2em] text-accent">Intelligent Workflow</p>
        <h2 class="text-4xl md:text-5xl font-black tracking-tighter italic">智能服务流程</h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
        {serviceFlow.map((s, i) => (
          <div class="animate-on-scroll bento-card group" style={`transition-delay: ${i * 100}ms`}>
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary mb-8 group-hover:bg-primary group-hover:text-white transition-all duration-500">
               <Icon name={s.icon} class="w-7 h-7" />
            </div>
            <h3 class="text-xl font-bold mb-4 italic tracking-tight">{s.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Detailed Case Studies -->
    <section class="py-32 space-y-40">
       <!-- Case 1: Finance -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
             <div class="animate-on-scroll animate-left">
                <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 inline-block">CASE STUDY 01 · 金融行业</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">金融级智能客服系统</h3>
                <div class="space-y-6 mb-10">
                   <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div class="p-6 rounded-3xl bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20 ">
                        <p class="text-[10px] font-bold text-primary uppercase mb-2">项目背景与挑战</p>
                        <p class="text-xs text-muted leading-relaxed">大型银行日咨询超10万，人工压力极大。专业问题复杂，培训成本高，对数据安全性有极高要求。</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20 ">
                        <p class="text-[10px] font-bold text-primary uppercase mb-2">解决方案</p>
                        <ul class="text-[10px] text-muted space-y-1 list-disc pl-3">
                          <li>本地部署 3B 模型确保安全</li>
                          <li>构建涵盖 90% 问题的知识图谱</li>
                          <li>多轮对话精准识别意图</li>
                        </ul>
                      </div>
                   </div>
                   <div class="grid grid-cols-3 gap-4">
                      <div class="p-4 rounded-2xl bg-emerald-500/5 border border-emerald-500/10 text-center">
                        <p class="text-xl font-black italic text-emerald-500">85%</p>
                        <p class="text-[8px] uppercase font-bold text-muted">解决率</p>
                      </div>
                      <div class="p-4 rounded-2xl bg-blue-500/5 border border-blue-500/10 text-center">
                        <p class="text-xl font-black italic text-blue-500">800万+</p>
                        <p class="text-[8px] uppercase font-bold text-muted">年节省成本</p>
                      </div>
                      <div class="p-4 rounded-2xl bg-orange-500/5 border border-orange-500/10 text-center">
                        <p class="text-xl font-black italic text-orange-500">99.9%</p>
                        <p class="text-[8px] uppercase font-bold text-muted">处理准确度</p>
                      </div>
                   </div>
                   <div class="p-8 rounded-[2.5rem] bg-slate-900 text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-10"><Icon name="lucide:banknote" class="w-20 h-20" /></div>
                      <h4 class="text-lg font-black mb-3 italic tracking-tight">场景故事</h4>
                      <p class="text-sm text-white/70 leading-relaxed italic">“某用户深夜需要由于紧急业务调整信用卡额度。系统立即响应，通过多轮对话调取用户画像与信用数据，在 3 分钟内完成评估，全程无需人工介入，用户给出了 5 星好评。”</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right relative">
                <img src="https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 2: E-commerce -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center flex-row-reverse">
             <div class="animate-on-scroll animate-left lg:order-2">
                <span class="text-accent text-xs font-bold uppercase tracking-widest mb-4 inline-block">CASE STUDY 02 · 电商行业</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">大促级智能应答平台</h3>
                <div class="space-y-6 mb-10">
                   <div class="p-6 rounded-3xl bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20">
                      <p class="text-xs font-bold text-accent uppercase mb-2">项目概况</p>
                      <p class="text-sm text-muted leading-relaxed">日均咨询超 50 万，订单与物流重复性咨询占比 70%。部署 7B 本地模型支持高并发，对接全业务系统。</p>
                   </div>
                   <div class="flex gap-4">
                      <div class="flex-1 p-6 rounded-3xl bg-accent/5 border border-accent/10">
                         <p class="text-2xl font-black italic text-accent">+200%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">服务效率提升</p>
                      </div>
                      <div class="flex-1 p-6 rounded-3xl bg-purple-500/5 border border-purple-500/10">
                         <p class="text-2xl font-black italic text-purple-500">78%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">全自动处理率</p>
                      </div>
                   </div>
                   <div class="p-8 rounded-[2.5rem] bg-accent text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-20"><Icon name="lucide:shopping-cart" class="w-20 h-20" /></div>
                      <h4 class="text-lg font-black mb-3 italic tracking-tight">场景故事</h4>
                      <p class="text-sm text-white/90 leading-relaxed italic">“双 11 期间，某用户咨询多个订单的发货状态与退换货。系统快速汇总所有订单信息，主动推送物流进度并自动预约上门取件，仅耗时 5 分钟，完全避免了咨询高峰期的排队。”</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right lg:order-1 relative">
                <img src="https://images.unsplash.com/photo-1557821552-17105176677c?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- More Cases in a compact grid -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="text-center mb-20 animate-on-scroll">
             <h2 class="text-4xl md:text-5xl font-black tracking-tighter italic">更多行业实践</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
             <!-- Case 3: Government -->
             <div class="animate-on-scroll bento-card p-10 flex flex-col justify-between">
                <div>
                   <div class="flex items-center justify-between mb-8">
                      <span class="text-[10px] font-bold uppercase tracking-widest text-primary">CASE 03 · 政务服务</span>
                      <Icon name="lucide:landmark" class="w-6 h-6 text-primary" />
                   </div>
                   <h4 class="text-2xl font-bold mb-4 italic tracking-tight">政务服务智能助手</h4>
                   <p class="text-sm text-muted mb-8 leading-relaxed">面对上千项繁杂政策，部署 3B 模型构建动态更新知识库。日均服务 5000+ 市民，政策解答准确率达 98%，窗口等待时间减少 65%。</p>
                   <div class="p-6 rounded-2xl bg-primary/5 italic border border-primary/10 text-xs mb-8">
                      “一位市民用方言咨询医保认证流程，助手通过语音交互详细讲解并代为预约就近办理点，提供了非常有温度的适老化服务。”
                   </div>
                </div>
                <div class="flex gap-6">
                   <div>
                      <p class="text-xl font-black italic text-primary">+40%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">满意度提升</p>
                   </div>
                   <div>
                      <p class="text-xl font-black italic text-primary">80%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">员工作业效率提升</p>
                   </div>
                </div>
             </div>
             
             <!-- Case 4: Knowledge -->
             <div class="animate-on-scroll bento-card p-10 flex flex-col justify-between shadow-primary/5">
                <div>
                   <div class="flex items-center justify-between mb-8">
                      <span class="text-[10px] font-bold uppercase tracking-widest text-accent">CASE 04 · 企业知识库</span>
                      <Icon name="lucide:folder-tree" class="w-6 h-6 text-accent" />
                   </div>
                   <h4 class="text-2xl font-bold mb-4 italic tracking-tight">企业智能大脑管理</h4>
                   <p class="text-sm text-muted mb-8 leading-relaxed">解决企业知识分散、检索难的问题。部署 7B 模型构建语义检索引擎与知识图谱。检索耗时降低 80%，新员工培训周期缩短 50%。</p>
                   <div class="p-6 rounded-2xl bg-accent/5 italic border border-accent/10 text-xs mb-8">
                      “新员工通过智能库即刻获取技术难题历史方案并获得最佳实践推荐，半小时内解决难题，效率飞跃。”
                   </div>
                </div>
                <div class="flex gap-6">
                   <div>
                      <p class="text-xl font-black italic text-accent">200%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">使用率提升</p>
                   </div>
                   <div>
                      <p class="text-xl font-black italic text-accent">300万+</p>
                      <p class="text-[8px] uppercase font-bold text-muted">年节省培训成本</p>
                   </div>
                </div>
             </div>

             <!-- Case 5: Dialogue -->
             <div class="animate-on-scroll bento-card p-10 flex flex-col justify-between">
                <div>
                   <div class="flex items-center justify-between mb-8">
                      <span class="text-[10px] font-bold uppercase tracking-widest text-emerald-500">CASE 05 · 对话管理</span>
                      <Icon name="lucide:message-square" class="w-6 h-6 text-emerald-500" />
                   </div>
                   <h4 class="text-2xl font-bold mb-4 italic tracking-tight">双向情感对话平台</h4>
                   <p class="text-sm text-muted mb-8 leading-relaxed">攻克复杂多轮对话理解难题。部署 7B 模型强化上下文管理，实现 92% 的理解准确率，平均对话轮次减少了 30%。</p>
                   <div class="p-6 rounded-2xl bg-emerald-500/5 italic border border-emerald-500/10 text-xs mb-8">
                      “系统能随用户话题变化精准捕捉需求，整个购买咨询过程自然流畅。用户直呼‘像在和真人聊天’。”
                   </div>
                </div>
                <div class="flex gap-6">
                   <div>
                      <p class="text-xl font-black italic text-emerald-500">60%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">对话完成率提升</p>
                   </div>
                   <div>
                      <p class="text-xl font-black italic text-emerald-500">-25%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">客户流失率下降</p>
                   </div>
                </div>
             </div>

             <!-- Case 6: Emotion -->
             <div class="animate-on-scroll bento-card p-10 flex flex-col justify-between">
                <div>
                   <div class="flex items-center justify-between mb-8">
                      <span class="text-[10px] font-bold uppercase tracking-widest text-pink-500">CASE 06 · 情感识别</span>
                      <Icon name="lucide:heart" class="w-6 h-6 text-pink-500" />
                   </div>
                   <h4 class="text-2xl font-bold mb-4 italic tracking-tight">情感化互动客服</h4>
                   <p class="text-sm text-muted mb-8 leading-relaxed">精准识别文本背后的情感倾向。部署专用 3B 情感模型，预警不满情绪。实现 NPS 提升 45 个百分点，投诉率减半。</p>
                   <div class="p-6 rounded-2xl bg-pink-500/5 italic border border-pink-500/10 text-xs mb-8">
                      “系统识别到用户退款时由于不耐烦而产生的负面情绪，自动切换为简洁高效的沟通风格并主动加速处理，成功将投诉转为好评。”
                   </div>
                </div>
                <div class="flex gap-6">
                   <div>
                      <p class="text-xl font-black italic text-pink-500">88%</p>
                      <p class="text-[8px] uppercase font-bold text-muted">情感识别准确率</p>
                   </div>
                   <div>
                      <p class="text-xl font-black italic text-pink-500">45pt</p>
                      <p class="text-[8px] uppercase font-bold text-muted">NPS 提升量</p>
                   </div>
                </div>
             </div>
          </div>
       </div>
    </section>

    <!-- Platform Advantages -->
    <section class="py-32 px-6 max-w-7xl mx-auto border-t border-border-light dark:border-primary/20 ">
      <div class="text-center mb-20 animate-on-scroll">
         <h2 class="text-4xl md:text-6xl font-black tracking-tighter italic mb-4">平台核心优势</h2>
         <p class="text-xl text-muted font-medium">基于本地部署的小模型解决方案</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {advantages.map((adv, i) => (
          <div class="animate-on-scroll p-10 rounded-3xl border border-border-light dark:border-primary/20 hover:border-primary transition-all group" style={`transition-delay: ${i * 50}ms`}>
            <div class="w-14 h-14 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mb-8 group-hover:scale-110 transition-transform">
               <Icon name={adv.icon} class="w-7 h-7" />
            </div>
            <h4 class="text-lg font-bold mb-4 italic tracking-tight">{adv.title}</h4>
            <p class="text-xs text-muted leading-relaxed font-medium">{adv.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6">
       <div class="animate-on-scroll bento-card max-w-4xl mx-auto text-center border-none bg-gradient-to-br from-primary to-accent text-white p-16 shadow-2xl relative overflow-hidden">
           <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/customer/1920/1080?blur=10')] opacity-20 mix-blend-overlay"></div>
           <div class="relative z-10">
              <h2 class="text-4xl md:text-7xl font-black tracking-tighter mb-8 italic">开启智能客服新时代</h2>
              <p class="text-xl text-white/80 mb-12 font-medium max-w-xl mx-auto">让我们助力您的企业提供更优质、更高效、更具温度的客户服务。</p>
              <div class="flex flex-wrap justify-center gap-6">
                <a href="/contact/" class="px-10 py-4 bg-white text-primary font-black italic rounded-full hover:scale-105 transition-all shadow-xl">立即预约演示</a>
              </div>
           </div>
       </div>
    </section>
  </main>
</Layout>
