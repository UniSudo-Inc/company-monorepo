---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const metadata = {
  title: '企业数字化解决方案 - UniSudo 智独数科技',
};

const stats = [
  { title: '服务效率', value: '200%+', desc: '平均效率大幅提升', icon: 'lucide:zap' },
  { title: '运营成本', value: '60%+', desc: '平均开支显著降低', icon: 'lucide:trending-down' },
  { title: '客户满意度', value: '40%+', desc: '交互体验深度优化', icon: 'lucide:smile' },
  { title: '数据安全', value: '100%', desc: '本地部署完整可控', icon: 'lucide:lock' }
];
---

<Layout metadata={metadata}>
  <main class="relative z-10 pt-0">
    <!-- Dynamic Background -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden -z-10">
      <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
      <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
    </div>

    <!-- Hero Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto text-center animate-on-scroll">
      <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
        SOLUTIONS · 企业数字化
      </span>
      <h1 class="text-6xl md:text-7xl font-black mb-8 tracking-tighter leading-[0.9]">
        企业数字化<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent text-5xl md:text-6xl italic">重塑产业动能</span>
      </h1>
      <p class="text-xl text-muted max-w-3xl mx-auto font-medium leading-relaxed">
        本地部署 · 全天候服务 · 数据安全。为企业提供端到端的 AI 驱动数字化转型方案，让技术真正服务于生产力。
      </p>
    </section>

    <!-- Case Studies: Immersive Blocks -->
    <section class="py-32 space-y-40">
       <!-- Case 1: Finance -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
             <div class="animate-on-scroll animate-left">
                <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 inline-block">FINANCIAL · 金融服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">金融服务智能问答系统</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-primary uppercase mb-3 text-primary/60">项目背景与目标</p>
                      <p class="text-sm text-muted leading-relaxed">
                        需求：提升金融服务响应效率，降低人工成本。痛点：专业知识更新频繁，人工培训成本高，服务质量不稳定。目标：打造安全可靠的智能金融顾问。
                      </p>
                   </div>
                   <div class="p-8 rounded-[2.5rem] bg-slate-900 text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-10"><Icon name="lucide:cpu" class="w-24 h-24" /></div>
                      <h4 class="text-xl font-black mb-3 italic tracking-tight">解决方案</h4>
                      <p class="text-sm text-white/70 leading-relaxed italic border-l-2 border-primary/50 pl-4">
                        部署 3B 本地小模型，确保数据安全。构建金融领域专业知识库，支持多轮对话理解。提供 7x24 小时专业咨询服务，实现金融产品精准推荐。
                      </p>
                   </div>
                   <div class="flex gap-6">
                      <div class="flex-1 p-8 rounded-[2.5rem] bg-emerald-500/5 border border-emerald-500/10">
                         <p class="text-3xl font-black italic text-emerald-500 tracking-tighter">95%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">问答准确率</p>
                      </div>
                      <div class="flex-1 p-8 rounded-[2.5rem] bg-primary/5 border border-primary/10">
                         <p class="text-3xl font-black italic text-primary tracking-tighter">-60%</p>
                         <p class="text-[10px] uppercase font-bold text-muted">人力成本降低</p>
                      </div>
                   </div>
                   <div class="p-6 border-t border-border-light dark:border-primary/20   pt-8">
                      <h4 class="text-lg font-bold mb-3 flex items-center gap-2"><Icon name="lucide:sparkles" class="w-5 h-5 text-primary" /> 技术亮点</h4>
                      <p class="text-xs text-muted leading-relaxed">采用 3B 小模型本地部署方案，无需联网，确保数据安全性。专业金融知识库让回答更精准，多轮对话能力让服务更自然。每月仅需一台普通服务器即可运行，大幅降低运营成本。</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right relative">
                <img src="https://images.unsplash.com/photo-1563986768609-322da13575f3?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 2: E-commerce -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center flex-row-reverse">
             <div class="animate-on-scroll animate-left lg:order-2">
                <span class="text-accent text-xs font-bold uppercase tracking-widest mb-4 inline-block">ECOMMERCE · 电商服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">电商全流程客服机器人</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-accent uppercase mb-3 text-accent/60">项目背景与目标</p>
                      <p class="text-sm text-muted leading-relaxed">
                        需求：提升电商服务效率，解决售前售后服务压力与节假日人力不足。目标：打造包含订单、物流、退换货的全流程智能服务体系。
                      </p>
                   </div>
                   <div class="p-8 rounded-[3rem] bg-accent text-white relative overflow-hidden group">
                      <div class="absolute -top-4 -right-4 opacity-20"><Icon name="lucide:shopping-bag" class="w-24 h-24" /></div>
                      <h4 class="text-xl font-black mb-3 italic tracking-tight">解决方案</h4>
                      <p class="text-sm text-white/90 leading-relaxed italic border-l-2 border-white/50 pl-4">
                        部署 7B 本地模型，保障数据隐私。实现订单查询与售后跟踪，整合商品推荐与比价，支持退换货智能处理及全球多语言客服。
                      </p>
                   </div>
                   <div class="grid grid-cols-3 gap-4">
                      <div class="p-6 rounded-3xl bg-accent/5 border border-accent/10 text-center">
                         <p class="text-2xl font-black italic text-accent pb-1">300%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">容量提升</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-purple-500/5 border border-purple-500/10 text-center">
                         <p class="text-2xl font-black italic text-purple-500 pb-1">+25%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">客单价增长</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-emerald-500/5 border border-emerald-500/10 text-center">
                         <p class="text-2xl font-black italic text-emerald-500 pb-1">-15%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">退货率降低</p>
                      </div>
                   </div>
                   <div class="p-6 bg-accent/5 rounded-3xl border border-accent/10">
                      <h4 class="text-lg font-bold mb-3 flex items-center gap-2"><Icon name="lucide:activity" class="w-5 h-5 text-accent" /> 技术亮点</h4>
                      <p class="text-xs text-muted leading-relaxed">本地部署 7B 小模型，断网环境也能稳定运行。个性化推荐算法提升成交率，智能工单分类提高处理效率。支持私有化部署，确保商业隐私。</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right lg:order-1 relative">
                <img src="https://images.unsplash.com/photo-1556742393-d75f468bfcb0?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 3: Government -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center">
             <div class="animate-on-scroll animate-left">
                <span class="text-primary text-xs font-bold uppercase tracking-widest mb-4 inline-block">GOVERNMENT · 政务服务</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">政务服务智能助手</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-primary uppercase mb-3 text-primary/60">项目背景与痛点</p>
                      <p class="text-sm text-muted leading-relaxed">
                        需求：提升政务效率，实现智能化咨询。痛点：政策更新频繁，解答效率低且咨询量大。目标：打造安全可靠的政策智能服务系统。
                      </p>
                   </div>
                   <div class="bento-card p-10 bg-primary/5 hover:border-primary/50 transition-all group">
                      <h4 class="text-xl font-black mb-4 italic tracking-tight flex items-center gap-2">
                        <Icon name="lucide:landmark" class="w-6 h-6 text-primary" />
                        解决方案
                      </h4>
                      <p class="text-sm text-muted leading-relaxed mb-6 italic border-l-4 border-primary pl-6">
                        基于 3B 本地模型确保护理。实现政务知识库实时更新、多部门业务深度协同、智能预约提醒及政策精准推送。
                      </p>
                      <div class="flex items-center gap-10">
                        <div>
                          <p class="text-2xl font-black italic text-primary">98%</p>
                          <p class="text-[10px] uppercase font-bold opacity-50">市民满意度</p>
                        </div>
                        <div>
                          <p class="text-2xl font-black italic text-primary">200%</p>
                          <p class="text-[10px] uppercase font-bold opacity-50">效率提升</p>
                        </div>
                      </div>
                   </div>
                   <div class="p-6 border-l-2 border-primary/20">
                      <h4 class="text-lg font-bold mb-3">安全特点</h4>
                      <p class="text-xs text-muted leading-relaxed">采用全量本地部署方案，确保政务敏感数据安全。支持物理隔离运行，稳定可靠。各部门独立部署，数据互不干扰，成本极度可控。</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right relative">
                <img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>

       <!-- Case 4: Power Grid -->
       <div class="px-6 max-w-7xl mx-auto">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-center flex-row-reverse">
             <div class="animate-on-scroll animate-left lg:order-2">
                <span class="text-orange-500 text-xs font-bold uppercase tracking-widest mb-4 inline-block">ENERGY · 电力能源</span>
                <h3 class="text-4xl font-black mb-10 italic tracking-tighter">国家电网智能服务平台</h3>
                <div class="space-y-8">
                   <div class="p-8 rounded-[2.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20  ">
                      <p class="text-xs font-bold text-orange-500 uppercase mb-3 text-orange-500/60">项目背景与痛点</p>
                      <p class="text-sm text-muted leading-relaxed">
                        需求：提升响应速度，解决用户咨询压力。痛点：24小时服务需求与突发事件压力。目标：打造安全、高可用的电力服务智能平台。
                      </p>
                   </div>
                   <div class="p-10 rounded-[3rem] bg-slate-900 text-white border-none group overflow-hidden relative">
                      <div class="absolute inset-0 bg-orange-500/5 group-hover:bg-orange-500/10 transition-colors"></div>
                      <div class="relative z-10">
                        <h4 class="text-xl font-black mb-6 italic tracking-tight">解决方案</h4>
                        <ul class="space-y-4 text-sm text-white/70 italic list-none">
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> 部署 3B 本地模型确保护网数据安全</li>
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> 电力故障自动诊断与账单智能解答</li>
                           <li class="flex items-start gap-3"><Icon name="lucide:check-circle" class="w-5 h-5 text-orange-500 shrink-0" /> 突发事件应急响应与工单智能分配</li>
                        </ul>
                      </div>
                   </div>
                   <div class="grid grid-cols-3 gap-6">
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">70%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">响应时间降低</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">55%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">运维成本降低</p>
                      </div>
                      <div class="p-6 rounded-3xl bg-orange-500/5 border border-orange-500/10 text-center">
                         <p class="text-2xl font-black italic text-orange-600 pb-1">99.9%</p>
                         <p class="text-[8px] uppercase font-bold text-muted">系统可用性</p>
                      </div>
                   </div>
                   <div class="p-6 border-r-2 border-orange-500/20 text-right">
                      <h4 class="text-lg font-bold mb-3 flex items-center justify-end gap-2">核心能力 <Icon name="lucide:zap" class="w-5 h-5 text-orange-500" /></h4>
                      <p class="text-xs text-muted leading-relaxed">专为电力行业设计的智能系统，支持高噪方言识别与电力术语专业处理，确保极端环境下电力服务的精准输出。</p>
                   </div>
                </div>
             </div>
             <div class="animate-on-scroll animate-right lg:order-1 relative">
                <img src="https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?q=80&w=1740&auto=format&fit=crop" class="rounded-[4rem] w-full aspect-square object-cover shadow-2xl" />
             </div>
          </div>
       </div>
    </section>

    <!-- Transition Impact: Results Dashboard -->
    <section class="py-32 px-6 max-w-7xl mx-auto border-t border-border-light dark:border-primary/20">
      <div class="text-center mb-20 animate-on-scroll">
         <h2 class="text-4xl md:text-6xl font-black tracking-tighter italic mb-4">转型成效统计</h2>
         <p class="text-xl text-muted font-medium">企业数字化转型效果一览</p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {stats.map((s, i) => (
          <div class="animate-on-scroll p-12 rounded-[3.5rem] bg-surface-light dark:bg-white/5 border border-border-light dark:border-primary/20 text-center group hover:scale-[1.02] transition-all" style={`transition-delay: ${i * 100}ms`}>
            <div class="w-16 h-16 rounded-2xl bg-primary/10 text-primary flex items-center justify-center mx-auto mb-10 group-hover:bg-primary group-hover:text-white transition-all">
               <Icon name={s.icon} class="w-8 h-8" />
            </div>
            <p class="text-5xl font-black italic tracking-tighter text-transparent bg-clip-text bg-gradient-to-br from-primary to-accent mb-4">{s.value}</p>
            <h4 class="text-xl font-bold mb-2 italic tracking-tight">{s.title}</h4>
            <p class="text-xs text-muted font-medium tracking-wide uppercase">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-32 px-6">
       <div class="animate-on-scroll bento-card max-w-5xl mx-auto text-center border-none bg-gradient-to-br from-[#0B123B] to-primary text-white p-16 md:p-24 shadow-2xl relative overflow-hidden">
           <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/enterprise/1920/1080?blur=10')] opacity-10 mix-blend-overlay"></div>
           <div class="relative z-10">
              <h2 class="text-4xl md:text-7xl font-black italic tracking-tighter mb-8">开启企业数字化转型</h2>
              <p class="text-xl text-white/80 mb-12 font-medium max-w-3xl mx-auto text-center">专业的数字化转型团队，为您量身定制专属方案。从策略到交付，我们与您并肩而行。</p>
              <div class="flex flex-wrap justify-center gap-6">
                <a href="/contact/" class="px-12 py-5 bg-white text-primary font-black italic rounded-full hover:scale-105 transition-all shadow-xl">立即联系转型顾问</a>
              </div>
           </div>
       </div>
    </section>
  </main>
</Layout>
