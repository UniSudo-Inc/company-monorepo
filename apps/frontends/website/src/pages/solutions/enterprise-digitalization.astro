---
import Layout from '@/layouts/PageLayout.astro';
import Content from '@/components/widgets/Content.astro';
import CallToAction from '@/components/widgets/CallToAction.astro';
import Timeline from '@/components/widgets/Timeline.astro';

const metadata = {
  title: '企业数字化解决方案',
};
---

<Layout metadata={metadata}>
  <div class='relative overflow-hidden'>
    <div class='absolute inset-0 bg-gradient-to-r from-primary to-accent opacity-90'></div>
    <div class='absolute inset-0 bg-[url("data:image/svg+xml,%3Csvg%20width%3D%2260%22%20height%3D%2260%22%20viewBox%3D%220%200%2060%2060%22%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%3E%3Cg%20fill%3D%22none%22%20fill-rule%3D%22evenodd%22%3E%3Cg%20fill%3D%22%23ffffff%22%20fill-opacity%3D%220.1%22%3E%3Cpath%20d%3D%22M36%2034v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6%2034v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6%204V0H4v4H0v2h4v4h2V6h4V4H6z%22%2F%3E%3C%2Fg%3E%3C%2Fg%3E%3C%2Fsvg%3E")] opacity-30'></div>
    <div class='relative z-10 mx-auto max-w-7xl px-4 py-24 sm:px-6 text-center'>
      <p class='mb-4 text-base font-bold uppercase tracking-[0.2em] text-white/80'>企业数字化</p>
      <h1 class='mb-6 text-4xl font-bold tracking-tight text-white md:text-6xl'>
        企业数字化解决方案
      </h1>
      <p class='mx-auto max-w-2xl text-xl text-white/90'>
        本地部署 · 全天候服务 · 数据安全
      </p>
    </div>
  </div>

  <Content
    isReversed
    tagline='案例研究'
    title='金融服务智能问答系统'
    items={[
      {
        title: '项目背景',
        description: '需求：提升金融服务响应效率，降低人工成本。痛点：专业知识更新频繁，人工培训成本高，服务质量不稳定。目标：打造安全可靠的智能金融顾问。',
      },
      {
        title: '解决方案',
        description: '部署3B本地小模型，确保数据安全。构建金融领域专业知识库，支持多轮对话理解。提供7x24小时专业咨询服务，实现金融产品精准推荐。',
      },
      {
        title: '实施效果',
        description: '响应时间降低至0.5秒，准确率达到95%，人力成本降低60%，客户满意度提升40%，本地部署月运营成本仅需5000元。',
      }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1563986768609-322da13575f3?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '金融智能客服',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>技术亮点</h3>
      <p class='text-muted leading-relaxed'>采用3B小模型本地部署方案，无需联网，确保数据安全性。专业金融知识库让回答更精准，多轮对话能力让服务更自然。每月仅需一台普通服务器即可运行，大幅降低运营成本。</p>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    tagline='案例研究'
    title='电商全流程客服机器人'
    items={[
      {
        title: '项目背景',
        description: '需求：提升电商服务效率，解决售前售后服务压力。痛点：节假日人力不足，客服培训周期长。目标：打造全流程智能服务体系。',
      },
      {
        title: '解决方案',
        description: '部署7B本地模型，保障数据隐私。订单查询与售后跟踪，商品推荐与比价服务，退换货智能处理，多语言客服支持。',
      },
      {
        title: '实施效果',
        description: '服务容量提升300%，客单价提升25%，退货率降低15%，月运营成本降低70%，本地部署每日仅需200元。',
      }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1556742393-d75f468bfcb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '电商客服',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>技术亮点</h3>
      <p class='text-muted leading-relaxed'>本地部署7B小模型，断网环境也能稳定运行。个性化推荐算法提升成交率，智能工单分类提高处理效率。支持私有化部署，确保商业数据安全。</p>
    </Fragment>
  </Content>

  <Content
    isReversed
    isAfterContent
    tagline='案例研究'
    title='政务服务智能助手'
    items={[
      {
        title: '项目背景',
        description: '需求：提升政务服务效率，实现智能化政务咨询。痛点：政策更新频繁，咨询量大，人工解答效率低。目标：打造安全可靠的政务智能服务系统。',
      },
      {
        title: '解决方案',
        description: '部署3B本地模型，确保数据安全。政务知识库实时更新，多部门业务协同，智能预约和提醒，政策精准推送服务。',
      },
      {
        title: '实施效果',
        description: '咨询效率提升200%，群众满意度达98%，人力投入降低50%，本地部署每月成本降低80%。',
      }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1542744173-8e7e53415bb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '政务服务',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>安全特点</h3>
      <p class='text-muted leading-relaxed'>采用本地部署方案，确保政务数据安全。支持离线运行，稳定可靠，成本低廉。每个部门可独立部署，数据互不干扰。</p>
    </Fragment>
  </Content>

  <Content
    isAfterContent
    tagline='案例研究'
    title='国家电网智能服务平台'
    items={[
      {
        title: '项目背景',
        description: '需求：提升电力服务响应速度，解决用户咨询压力。痛点：24小时服务需求大，突发事件处理压力大。目标：打造安全可靠的电力服务智能平台。',
      },
      {
        title: '解决方案',
        description: '部署3B本地小模型，确保电网数据安全。电力故障智能诊断系统，用电账单智能解答，突发事件应急响应，智能工单分配机制。',
      },
      {
        title: '实施效果',
        description: '故障响应时间降低70%，客户满意度提升45%，运维成本降低55%，系统可用性达99.9%。',
      }
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1473341304170-971dccb5ac1e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: '电力服务',
    }}
  >
    <Fragment slot='content'>
      <h3 class='text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4'>核心能力</h3>
      <p class='text-muted leading-relaxed'>专为电力行业设计的智能客服系统，支持方言识别，专业术语处理，确保电力服务的安全性和准确性。</p>
    </Fragment>
  </Content>

  <Timeline
    title='企业数字化转型效果'
    items={[
      {
        title: '服务效率',
        description: '平均提升200%以上',
      },
      {
        title: '运营成本',
        description: '平均降低60%以上',
      },
      {
        title: '客户满意度',
        description: '平均提升40%以上',
      },
      {
        title: '数据安全',
        description: '本地部署，数据完全自主可控',
      },
    ]}
  />

  <div class='relative'>
    
    <CallToAction
      title='开启企业数字化转型'
      subtitle='专业团队为您定制专属的企业数字化方案'
      actions={[
        {
          variant: 'primary',
          text: '立即咨询',
          href: '/contact/',
          icon: 'tabler:messages',
        },
      ]}
    />
  </div>
</Layout>