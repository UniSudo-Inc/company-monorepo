  {
    title: '技术创新',
    description: '突破传统架构限制，实现低成本、高效能的 AI 解决方案。',
    icon: 'lucide:rocket',
  },
  {
    title: '场景理解',
    description: '深度理解垂直领域需求，提供精准的行业解决方案。',
    icon: 'lucide:component',
  },
  {
    title: '成本优势',
    description: '通过创新技术架构大幅降低部署和运营成本。',
    icon: 'lucide:coins',
  },
  {
    title: '生态完整',
    description: '自主研发全流程技术链，提供一站式服务能力。',
    icon: 'lucide:layers',
  },
];

const solutions = [
  {
    title: "虚拟数字人与流式对话",
    subtitle: "毫秒级响应的实时交互体验，为数字展厅与智能客服赋予灵魂。",
    category: "交互创新",
    image: "https://images.openai.com/static-rsc-4/8PPBBVXur7C-XIWP1_phZtYp55i3isw-Vb-45CD9lUCMQjg2WqrvIyV-Z_fQhGwvRQsOy3DlxLGvK2j51YTNOvQR1TeMWQH5lDkwGQqbuwLRcz0_PpLDOnoQ8U7VCtKw9zzT4_iMbVijDc_ruuFbgLnFC8yMHxGVjd5NTod20h_ZJiqyLGvghp73_mKzZXLt?purpose=inline",
    items: [
      "业界领先的流式可打断技术",
      "高保真数字人视觉渲染",
      "多轮对话上下文深度记忆",
      "极低时延的端到端响应"
    ]
  },
  {
    title: "边缘计算硬件解决方案",
    subtitle: "软硬一体化深度定制，实现工业级私有化模型部署与数据安全保障。",
    category: "基础设施",
    image: "https://images.openai.com/static-rsc-4/FyUWuvjde8DLAJvTwXLOnt4mrvxJ5BieHOYaK6SBtSCQnVXJJljMsBshKLy5cvHgeM-BaEBJXtwXPnr5XcXh-41jX84FfjFtu6B9_Jw9r_sInVcYRXNj-jAGJmCupfzVKn5DcRuo5sHXYrzQONfwAAWy-mIrxSoJugM8jGEEft0EFKTnhYTcDulFsBHNuzNM?purpose=inline",
    items: [
      "支持本地化国产化算力适配",
      "灵活对接多厂商传感器接口",
      "私有模型压缩与量化优化",
      "工业级 7*24h 稳定运行"
    ]
  },
  {
    title: "企业级云原生工作流",
    subtitle: "打通 AI 应用与业务系统间的最后一公里，实现全自动化流程再造。",
    category: "组织提效",
    image: "https://images.openai.com/static-rsc-4/rClkOUPwQtWlbhC1QbL-0MuSIks_gezzFmbBP4a8n7qFG7cl_8TveMpaAsrRKu_dttBGz-eMx2_abJ-vhimVkRaIuzrjqhoX5qHeT9sOcKqeuVVHXQ_GI6X1rTcJtAVfWd7pVuF7sT3bEdqhH-xhJB6bOmcQ4oZLETr-aNTp_ciJqZEePfiiCVQOzMWjENlz?purpose=inline",
    items: [
      "标准化的 Function Call 插件",
      "弹性伸缩的云原生 API 集群",
      "精细化的 Token 消耗监控",
      "多角色协作的任务流引擎"
    ]
  }
];

const scenarios = [
  {
    title: '数字人展厅',
    description: ['银行智能网点数字员工', '博物馆虚拟讲解员', '企业展厅互动导购', '商场数字导购助手'],
    icon: 'lucide:user',
  },
  {
    title: '数据服务',
    description: ['AI 训练数据标注', '多模态数据处理', '数据清洗与增强', '数据质量评估体系'],
    icon: 'lucide:database',
  },
  {
    title: '模型训练',
    description: ['大模型微调训练', '垂直领域模型开发', '多模态模型部署', '模型性能优化'],
    icon: 'lucide:brain',
  },
  {
    title: '智能客服',
    description: ['金融服务智能问答', '电商客服机器人', '多轮对话管理', '情感识别服务'],
    icon: 'lucide:headset',
  },
  {
    title: '企业数字化',
    description: ['智能人才筛选', '企业培训助手', '办公自动化平台', '辅助决策系统'],
    icon: 'lucide:building',
  },
  {
    title: '行业解决方案',
    description: ['教育培训数字化', '医疗健康智能诊疗', '金融风控分析', '零售智能化升级'],
    icon: 'lucide:bar-chart-3',
  },
];

const metadata = {
  title: '上海智独数科技有限公司 — 赋能SUDO权限的独特AI解决方案',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Dynamic Background -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-primary/5 rounded-full blur-[120px] animate-pulse"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/5 rounded-full blur-[120px] animate-pulse" style="animation-delay: 2s"></div>
  </div>

  <main class="relative z-10">
    <!-- Hero Section -->
    <section class="min-h-screen flex flex-col items-center justify-center px-6 text-center relative overflow-hidden">
      <div class="animate-on-scroll">
        <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-widest mb-6 inline-block">
          SUDO 权限 · 独特 AI 解决方案
        </span>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 100ms">
        <h1 class="text-5xl md:text-7xl font-black mb-8 leading-[1.1] tracking-tighter max-w-5xl">
          赋能 SUDO 权限的 <br />
          <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">独特 AI 解决方案</span>
        </h1>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 200ms">
        <p class="text-xl text-muted max-w-3xl mx-auto mb-10 leading-relaxed font-medium">
          <span class="font-bold text-primary block mb-2 md:inline md:mb-0">上海智独数科技有限公司</span>
          致力于打造高效能、低成本的 AI 解决方案。通过创新的模型架构和全流程技术支持，我们帮助企业以远低于传统方案的成本实现 AI 的精准落地。
        </p>
      </div>
      <div class="animate-on-scroll" style="transition-delay: 300ms">
        <div class="flex flex-wrap items-center justify-center gap-4">
          <a href="#products">
            <button class="btn-primary text-lg px-8 py-4">
              产品矩阵
            </button>
          </a>
          <a href="/about/" class="px-8 py-4 rounded-full border border-gray-200  dark:border-primary/20 font-medium hover:bg-black/5 dark:hover:bg-white/5 transition-all">
            公司简介
          </a>
        </div>
      </div>

      <!-- Stats Bar -->
      <div class="animate-on-scroll mt-24 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-20" style="transition-delay: 400ms">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-3xl md:text-4xl font-bold mb-1 tracking-tight">{s.value}</div>
            <div class="text-xs text-muted font-bold uppercase tracking-widest">{s.label}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Core Competency Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto border-t border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll text-center mb-20">
        <span class="text-primary font-bold tracking-widest uppercase text-xs mb-4 block">Core Competency</span>
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-6">业内专家 + 创新思维 + 技术研发</h2>
        <p class="text-muted text-lg max-w-3xl mx-auto">
          上海智独数科技持续深化技术创新，专注于为企业提供更高效、更经济的 AI 落地方案。
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {coreCompetencies.map((c, i) => (
          <div class="animate-on-scroll p-8 rounded-3xl bg-white dark:bg-[#030620] border border-gray-100  dark:border-primary/20 group hover:border-primary/50 transition-all duration-500" style={`transition-delay: ${i * 100}ms`}>
            <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary mb-6 group-hover:scale-110 transition-transform">
              <Icon name={c.icon} class="w-6 h-6" />
            </div>
            <h3 class="text-xl font-bold mb-4">{c.title}</h3>
            <p class="text-sm text-muted leading-relaxed">{c.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Solutions Showcase Section -->
    <section class="py-32 px-6 max-w-7xl mx-auto bg-surface-light dark:bg-surface-dark/30 rounded-[3rem] overflow-hidden border border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">满足您对 AI 的全部需求</h2>
        <p class="text-muted text-lg">矩阵式产品体系，助力企业全生命周期数字化转型</p>
      </div>

      <div class="space-y-40">
        {solutions.map((s, i) => (
          <div class={`flex flex-col ${i % 2 === 0 ? 'lg:flex-row' : 'lg:flex-row-reverse'} gap-16 items-center lg:items-center`}>
            <div class="reveal lg:w-3/5" style={`transition-delay: ${i * 100}ms`}>
              <div class="relative group perspective-1000">
                <div class="absolute -inset-4 bg-gradient-to-tr from-primary/20 to-accent/20 rounded-[4rem] blur-2xl opacity-0 group-hover:opacity-100 transition-all duration-700 -z-10 scale-95 group-hover:scale-105"></div>
                <div class="overflow-hidden rounded-[3rem] border border-border-light dark:border-white/10 shadow-2xl transition-transform duration-700 group-hover:scale-[1.02]">
                  <img 
                    src={s.image} 
                    alt={s.title} 
                    referrerpolicy="no-referrer"
                    class="w-full object-cover aspect-[16/10] grayscale-[0.3] group-hover:grayscale-0 transition-all duration-700" 
                  />
                </div>
                <!-- Decorative Badge -->
                <div class="absolute -bottom-6 -right-6 md:right-12 bg-white dark:bg-[#030620] px-8 py-4 rounded-2xl shadow-xl border border-border-light dark:border-primary/20 hidden md:block">
                  <div class="flex items-center gap-3">
                    <div class="w-2 h-2 rounded-full bg-primary animate-ping"></div>
                    <span class="text-xs font-black uppercase tracking-[0.2em]">{s.category}</span>
                  </div>
                </div>
              </div>
            </div>
            <div class="reveal lg:w-2/5" style={`transition-delay: ${(i * 100) + 150}ms`}>
              <div class="flex items-center gap-3 mb-6">
                 <span class="w-12 h-px bg-primary/30"></span>
                 <span class="text-xs font-bold text-primary uppercase tracking-[0.3em]">{s.category}</span>
              </div>
              <h3 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter italic leading-tight">{s.title}</h3>
              <p class="text-lg text-muted mb-10 leading-relaxed font-medium italic pr-4">{s.subtitle}</p>
              <div class="grid grid-cols-1 gap-4">
                {s.items.map(item => (
                  <div class="flex items-center gap-4 group/item">
                    <div class="w-8 h-8 rounded-lg bg-primary/5 flex items-center justify-center text-primary group-hover/item:bg-primary group-hover/item:text-white transition-all duration-300">
                      <Icon name="lucide:arrow-right-circle" class="w-4 h-4" />
                    </div>
                    <span class="text-sm font-bold text-muted group-hover/item:text-default transition-colors">{item}</span>
                  </div>
                ))}
              </div>
              <div class="mt-12">
                <a href="/contact/" class="group flex items-center gap-3 text-sm font-black uppercase tracking-widest text-primary hover:text-accent transition-colors">
                  申请演示方案 <Icon name="lucide:chevron-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- AI Application Scenarios -->
    <section class="py-32 px-6 max-w-7xl mx-auto">
      <div class="animate-on-scroll text-center mb-20">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">AI 应用场景</h2>
        <p class="text-muted text-lg">赋能智造、交通、客服、企业服务等多个垂直领域</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {scenarios.map((s, i) => (
          <div class="animate-on-scroll bento-card flex flex-col group" style={`transition-delay: ${i * 100}ms`}>
            <div class="flex items-center gap-4 mb-6">
              <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary group-hover:bg-primary group-hover:text-white transition-all">
                <Icon name={s.icon} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold">{s.title}</h3>
            </div>
            <ul class="space-y-3">
              {s.description.map(item => (
                <li class="text-sm text-muted flex items-center gap-2">
                  <span class="w-1.5 h-1.5 bg-primary/30 rounded-full"></span>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Product Matrix Section -->
    <section id="products" class="py-32 px-6 max-w-7xl mx-auto border-t border-gray-100  dark:border-primary/20">
      <div class="animate-on-scroll mb-20 text-center">
        <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-4">产品矩阵</h2>
        <p class="text-muted text-lg max-w-2xl mx-auto">针对特定痛点打造的高端 AI 产品线。</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {products.map((p, i) => (
          <a href={p.href} target={p.id==='a1' ? '_blank' : undefined} class="animate-on-scroll group block" style={`transition-delay: ${i * 100}ms`}>
            <div class="bento-card h-full flex flex-col p-8 group-hover:border-primary/50 transition-all duration-500 overflow-hidden relative">
              <div class={`absolute -top-10 -right-10 w-40 h-40 bg-gradient-to-br ${p.color} opacity-[0.03] group-hover:opacity-10 rounded-full blur-3xl transition-opacity duration-700`}></div>
              <div class={`w-14 h-14 rounded-2xl bg-gradient-to-br ${p.color} flex items-center justify-center text-white mb-8 shadow-lg group-hover:scale-110 transition-transform duration-500`}>
                <Icon name={p.icon} class="w-7 h-7" />
              </div>
              <div class="flex-grow">
                <div class="flex items-center justify-between mb-2">
                  <span class="text-xs font-bold uppercase tracking-widest text-primary opacity-70">{p.tagline}</span>
                  <Icon name="lucide:arrow-right" class="w-4 h-4 opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all" />
                </div>
                <h3 class="text-2xl font-bold mb-4 tracking-tight">{p.title}</h3>
                <p class="text-muted leading-relaxed text-sm">{p.desc}</p>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Unified Experience Block -->
    <section id="about" class="py-24 px-6 max-w-7xl mx-auto">
      <div class="animate-on-scroll bento-card border-none bg-gradient-to-br from-indigo-900 to-purple-900 text-white p-12 md:p-20 overflow-hidden relative">
        <div class="absolute inset-0 bg-[url('https://picsum.photos/seed/tech/1920/1080?blur=10')] opacity-20 mix-blend-overlay"></div>
        <div class="relative z-10 max-w-2xl">
          <h2 class="text-4xl md:text-6xl font-bold tracking-tighter mb-8 italic">让 AI 真正深入业务场景</h2>
          <p class="text-lg text-white/80 mb-10 leading-relaxed font-medium">
            我们不只是提供工具，更是提供深度集成、安全合规、可落地的业务智能化路径。
            无论是私有化部署还是云端协同，UniSudo 都是您最可靠的 AI 合作伙伴。
          </p>
          <div class="flex gap-4">
            <a href="/contact/" class="bg-white text-indigo-900 px-8 py-3 rounded-full font-bold hover:bg-neutral-100 transition-colors">联系我们咨询</a>
            <a href="/career/" class="bg-white/10 text-white px-8 py-3 rounded-full font-bold backdrop-blur-sm border border-white/20 hover:bg-white/20 transition-colors">加入我们</a>
          </div>
        </div>
        <div class="absolute bottom-[-10%] right-[-5%] w-[40%] h-[80%] hidden lg:block opacity-40">
           <div class="w-full h-full border-[20px] border-white/10 rounded-full animate-spin" style="animation-duration: 20s"></div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .glass {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
  }
  
  :global(.dark) .glass {
    background: rgba(3, 6, 32, 0.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }
</style>
