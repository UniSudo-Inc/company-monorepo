---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/PageLayout.astro';

const products = [
  {
    id: "a2",
    title: "智能员工 (A2)",
    tagline: "常驻式个人智能操作系统",
    desc: "不仅是 AI 助手，更是你的个人智能团队。基于 Rust 构建的常驻式系统，支持分层协作、并行执行与长期记忆沉淀。",
    icon: "lucide:message-square",
    color: "from-blue-500 to-indigo-600",
    href: "/products/a2/"
  },
  {
    id: "a1",
    title: "无代码 AI 中台 (A1)",
    tagline: "企业数字化底座",
    desc: "一站式无代码 AI 应用开发平台。通过拖拽即可构建复杂的 AI 工作流，兼容国内外主流大模型，快速赋能业务场景。",
    icon: "lucide:cpu",
    color: "from-purple-500 to-violet-600",
    href: "https://a1.v8.unisudo.dev/"
  },
  {
    id: "uniteach",
    title: "AI 智能阅卷 (UniTeach)",
    tagline: "教育行业深度审查",
    desc: "专注于教育垂直领域的智能评估系统。支持多模态识别与个性化评语生成，让教学评估更客观、更高效。",
    icon: "lucide:graduation-cap",
    color: "from-orange-500 to-red-600",
    href: "/products/uniteach/"
  },
  {
    id: "unibusiness",
    title: "出海会议同传 (UniBusiness)",
    tagline: "跨语言协作利器",
    desc: "实时 AI 会议同传。支持主流会议软件，提供实时翻译、双语理解与智能纪要，助推全球化高效协作。",
    icon: "lucide:languages",
    color: "from-emerald-500 to-teal-600",
    href: "/products/unibusiness/"
  },
  {
    id: "uniclause",
    title: "智能合同审查 (UniClause)",
    tagline: "可解释的风险控制",
    desc: "基于 RAG 架构的合同深度分析平台。让每一份合同审查都有据可查，精准识别风险并生成修订建议。",
    icon: "lucide:shield-check",
    color: "from-indigo-500 to-purple-600",
    href: "/products/uniclause/"
  }
];

const stats = [
  { label: "服务企业", value: "200+" },
  { label: "平均提效", value: "75%" },
  { label: "模型处理", value: "10B+" },
  { label: "数据安全", value: "金融级" }
];

