---
---

<div class="relative w-full max-w-2xl mx-auto aspect-[4/3] bg-surface rounded-3xl border border-border-light  dark:border-primary/20 overflow-hidden shadow-2xl">
  {/* Grid Background */}
  <div class="absolute inset-0 opacity-[0.03] dark:opacity-[0.07]" 
       style="background-image: radial-gradient(circle, currentColor 1px, transparent 1px); background-size: 24px 24px;"></div>
  
  {/* Top Bar */}
  <div class="absolute top-0 left-0 w-full h-12 border-b border-border-light  dark:border-primary/20 bg-surface/50 backdrop-blur-sm flex items-center px-6 justify-between">
    <div class="flex gap-2">
      <div class="w-3 h-3 rounded-full bg-red-400/20"></div>
      <div class="w-3 h-3 rounded-full bg-yellow-400/20"></div>
      <div class="w-3 h-3 rounded-full bg-green-400/20"></div>
    </div>
    <div class="text-[10px] font-mono tracking-widest uppercase text-text-muted">AI Analysis Mode</div>
  </div>

  {/* Content Area */}
  <div class="absolute inset-0 pt-12 flex flex-col items-center justify-center p-12">
    
    {/* Math Formula Example */}
    <div class="relative bg-white dark:bg-slate-900 p-10 rounded-2xl shadow-lg border border-border/50 mb-12 animate-fade-in-up">
      <div class="text-4xl font-serif italic text-slate-800 dark:text-slate-200 flex items-center gap-4">
        <span class="relative">
          ∫ 
          <div class="absolute -bottom-1 -left-1 w-3 h-3 rounded-full border-2 border-primary animate-pulse-scale"></div>
        </span>
        <div class="flex flex-col items-center">
          <span class="border-b-2 border-slate-800 dark:border-slate-200 pb-1">x² sin(x)</span>
          <span class="pt-1">eˣ</span>
        </div>
        <span>dx = ...</span>
      </div>

      {/* Labels */}
      <div class="absolute -bottom-4 -left-4 bg-slate-900 text-white text-[10px] font-bold px-3 py-1 rounded flex items-center gap-2 animate-slide-in-left">
        <div class="w-1.5 h-1.5 rounded-full bg-primary animate-pulse"></div>
        SYMBOL
      </div>

      <div class="absolute top-4 -right-8 bg-primary/10 text-primary text-[10px] font-bold px-3 py-1 rounded-full border border-primary/20 animate-slide-in-right">
        COMPLEX_TERM
      </div>
    </div>

    {/* Question Analysis */}
    <div class="w-full bg-white dark:bg-slate-900 p-8 rounded-2xl shadow-lg border border-border/50 relative overflow-hidden animate-fade-in-up delay-1000">
      {/* Scanning Line */}
      <div class="absolute left-0 w-full h-[2px] bg-red-500/50 z-10 animate-scan"></div>

      <div class="space-y-4 opacity-80">
        <div class="h-4 w-3/4 bg-slate-100 dark:bg-slate-800 rounded"></div>
        <div class="relative border-2 border-dashed border-green-400/30 p-3 rounded-lg">
          <div class="absolute -top-3 left-2 bg-green-400 text-white text-[8px] font-bold px-2 py-0.5 rounded">Q-ZONE</div>
          <div class="h-3 w-full bg-slate-100 dark:bg-slate-800 rounded"></div>
        </div>
        <div class="relative border-2 border-dashed border-blue-400/30 p-3 rounded-lg">
          <div class="absolute -top-3 left-2 bg-blue-400 text-white text-[8px] font-bold px-2 py-0.5 rounded">A-ZONE</div>
          <div class="h-3 w-1/2 bg-slate-100 dark:bg-slate-800 rounded"></div>
          <div class="h-3 w-2/3 bg-slate-100 dark:bg-slate-800 rounded mt-2"></div>
        </div>
      </div>
    </div>
  </div>

  {/* Decorative corner elements */}
  <div class="absolute bottom-4 right-4 flex gap-4">
    <div class="text-[8px] font-mono text-text-muted">LATENCY: 12ms</div>
    <div class="text-[8px] font-mono text-text-muted">CONFIDENCE: 99.8%</div>
  </div>
</div>

<style>
  .animate-fade-in-up {
    animation: fade-in-up 1s ease-out forwards;
  }
  
  .animate-pulse-scale {
    animation: pulse-scale 2s ease-in-out infinite;
  }
  
  .animate-slide-in-left {
    animation: slide-in-left 0.5s ease-out 0.5s forwards;
    opacity: 0;
  }
  
  .animate-slide-in-right {
    animation: slide-in-right 0.5s ease-out 0.8s forwards;
    opacity: 0;
  }
  
  .animate-scan {
    animation: scan 4s linear infinite;
  }

  .delay-1000 {
    animation-delay: 1s;
  }

  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px) scale(0.9); }
    to { opacity: 1; transform: translateY(0) scale(1); }
  }

  @keyframes pulse-scale {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.2); }
  }

  @keyframes slide-in-left {
    from { opacity: 0; transform: translateX(-10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes slide-in-right {
    from { opacity: 0; transform: translateX(10px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes scan {
    0%, 100% { top: 0%; }
    50% { top: 100%; }
  }
</style>
