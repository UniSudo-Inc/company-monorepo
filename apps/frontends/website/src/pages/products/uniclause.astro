---
import { Icon } from 'astro-icon/components';
import Layout from '@/layouts/LandingLayout.astro';

const metadata = {
  title: 'UniClause - 智能合同审查系统',
};

const sellingPoints = [
  {
    icon: "lucide:layers",
    title: "可解释的 AI 审查",
    desc: "传统方案直接输出结果，无法验证依据，UniClause 确保每个结论都能追溯到具体段落。"
  },
  {
    icon: "lucide:zap",
    title: "大合同也能审",
    desc: "段落级分块 + 向量检索，突破窗口限制。100 页合同精准匹配，成本降低 60%+"
  },
  {
    icon: "lucide:refresh-ccw",
    title: "核查点独立运算",
    desc: "调整一个核查点无需重审全文。秒级响应变更，支持实时迭代审查策略。"
  },
  {
    icon: "lucide:fingerprint",
    title: "缺失条款自动发现",
    desc: "从“人找条款”到“AI 主动发现”。语义相似度阈值判定缺失，标记并生成补全建议。"
  },
  {
    icon: "lucide:database",
    title: "成本极致可控",
    desc: "IndexedDB 本地存储，无需后端向量库依赖。使用国产模型，API 成本大幅降低。"
  },
  {
    icon: "lucide:shield-check",
    title: "数据不出域",
    desc: "敏感数据留于本地，脱敏后再喂给 AI。企业版本地完全离线运行，严控泄密风险。"
  }
];

const scenarios = [
  {
    title: "律所批量审查",
    pain: "合同量大、时间紧，Junior 律师经验不足导致标准不一。",
    solution: "RAG 快速定位关键条款，自动生成标准化审查意见，提高产出一致性。"
  },
  {
    title: "企业法务合规",
    pain: "合同版本多，人工比对难以确保每版都覆盖全部核查点。",
    solution: "通过预设核查清单自动比对，主动发现缺失条款，确保合规闭环。"
  },
  {
    title: "投资/并购尽调",
    pain: "长篇交易文件，对赌、优先权等核心条款分散各处，极易遗漏。",
    solution: "向量化检索秒级扫描百页文件，精准提取核心条款，降低尽调风险。"
  },
  {
    title: "金融机构风控",
    pain: "监管要求极高，审查过程需留痕审计，黑盒 AI 无法满足合规需求。",
    solution: "可解释架构为每个结论提供溯源依据与分数，满足严苛的审计要求。"
  }
];

const techHighlights = [
  { title: "RAG 并发架构", desc: "Per-Checkpoint 独立检索，审查速度提升 5-10 倍" },
  { title: "混合存储模式", desc: "IndexedDB 本地缓存向量，零后端依赖，响应无延迟" },
  { title: "国产底座适配", desc: "深度适配 DashScope, DeepSeek 等模型，合规且成本可控" }
];

const comparisonData = [
  ["架构原理", "整文直给 (单次 LLM 调用)", "RAG 架构 (段落级检索 + 生成)"],
  ["可解释性", "黑盒输出，无法验证", "可溯源 (召回段落 + 相似度分数)"],
  ["长度上限", "长合同被迫截断", "无限制 (向量检索突破 Token 上限)"],
  ["更新模式", "改一条重审全篇", "单点更新 (核查点独立分析)"],
  ["缺失识别", "人工经验寻找", "AI 主动发现 (语义阈值判定)"],
  ["数据安全", "必须上传服务器", "敏感数据本地脱敏，支持纯本地化"],
  ["计费模式", "高额固定年费", "按量/年费/买断灵活可选"]
];
---

<Layout metadata={metadata}>
  <div class="fixed inset-0 pointer-events-none overflow-hidden z-0">
    <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-[120px]"></div>
    <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-accent/5 rounded-full blur-[120px]"></div>
  </div>

  <!-- <nav class="fixed top-0 w-full z-50 glass">
    <div class="max-w-7xl mx-auto px-6 h-20 flex items-center justify-between">
      <div class="flex items-center gap-4">
        <a href="/" class="p-2 hover:bg-black/5 dark:hover:bg-white/5 rounded-lg transition-colors group">
          <Icon name="lucide:chevron-left" class="w-5 h-5 group-hover:-translate-x-1 transition-transform" />
        </a>
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
            <Icon name="lucide:shield-check" class="text-white w-6 h-6" />
          </div>
          <span class="text-xl font-bold tracking-tighter">UniClause</span>
        </div>
      </div>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium">
        <a href="#features" class="hover:text-primary transition-colors">核心功能</a>
        <a href="#selling-points" class="hover:text-primary transition-colors">核心卖点</a>
        <a href="#pricing" class="hover:text-primary transition-colors">价格体系</a>
        <a href="#comparison" class="hover:text-primary transition-colors">竞品对比</a>
      </div>
      <button class="btn-primary flex items-center gap-2 text-sm">
        立即体验 <Icon name="lucide:arrow-right" class="w-4 h-4" />
      </button>
    </div>
  </nav> -->

  <main class="relative z-10 pt-18">
    <!-- Hero Section -->
    <section class="px-6 pt-20 pb-30 max-w-7xl mx-auto text-center">
      <div class="reveal">
        <span class="px-4 py-1.5 rounded-full bg-primary/10 text-primary text-xs font-bold uppercase tracking-wider mb-6 inline-block">
          让审查有源可溯 · 让 AI 真正可解释
        </span>
      </div>
      <div class="reveal" style="transition-delay: 100ms">
        <h1 class="text-5xl md:text-7xl mb-8 leading-[1.1] font-extrabold max-w-5xl mx-auto tracking-tighter text-primary">
          UniClause <br />
          <span class="bg-gradient-to-r from-primary to-accent bg-clip-text text-transparent">AI 智能合同审查</span>
        </h1>
      </div>
      <div class="reveal" style="transition-delay: 200ms">
        <p class="text-lg md:text-xl text-muted max-w-3xl mx-auto mb-10 leading-relaxed">
          让每一份合同审查都有据可查、有源可溯、有理可循。 <br class="hidden md:block" />
          基于 RAG 架构驱动的可解释 AI 平台，告别“黑盒”判断，重塑法务工作流。
        </p>
      </div>
      <div class="reveal" style="transition-delay: 300ms">
        <div class="flex flex-wrap items-center justify-center gap-4">
          <button class="btn-primary text-lg px-8 py-4">
            开始免费试用
          </button>
          <button class="px-8 py-4 rounded-full border border-border-light dark:border-border-dark font-medium hover:bg-black/5 dark:hover:bg-white/5 transition-all">
            预约演示
          </button>
        </div>
      </div>
    </section>

    <!-- Bento Grid Features -->
    <section id="features" class="px-6 py-24 max-w-7xl mx-auto">
      <div class="reveal text-center mb-16">
        <h2 class="text-3xl md:text-5xl mb-4">核心功能</h2>
        <p class="text-muted">全流程闭环，从风险识别到条款补全</p>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-12 gap-6 auto-rows-[300px]">
        {/* Feature 1: Large */}
        <div class="reveal md:col-span-8 bento-card flex flex-col justify-between group overflow-hidden relative">
          <div class="absolute top-0 right-0 p-8 opacity-10 group-hover:scale-110 group-hover:opacity-20 transition-all duration-700">
            <Icon name="lucide:search" class="w-48 h-48" />
          </div>
          <div class="absolute bottom-0 right-0 w-1/2 h-2/3 opacity-30 group-hover:opacity-60 transition-opacity duration-500 pointer-events-none translate-x-10 translate-y-10">
            <div class="w-full h-full rounded-tl-3xl shadow-2xl skew-x-[-10deg] skew-y-[-5deg] bg-primary/20 border border-primary/30 flex flex-col p-6 gap-2">
              <div class="h-2 bg-primary/30 rounded-full w-3/4"></div>
              <div class="h-2 bg-primary/10 rounded-full w-full"></div>
              <div class="h-2 bg-primary/10 rounded-full w-5/6"></div>
              <div class="h-2 bg-red-500/30 rounded-full w-2/3"></div>
              <div class="mt-4 flex flex-col gap-1">
                <div class="h-1 bg-primary/5 rounded-full w-full"></div>
                <div class="h-1 bg-primary/5 rounded-full w-full"></div>
              </div>
            </div>
          </div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="lucide:cpu" class="text-primary w-6 h-6" />
            </div>
            <h3 class="text-2xl mb-4">智能条款提取与风险识别</h3>
            <p class="text-muted max-w-md">
              自建审核组和审核点，基于段落级 RAG 检索，自动召回最相关的条款落段，实现风险分级与双向对照修改。
            </p>
          </div>
          <div class="flex items-center gap-4 mt-8">
            <span class="px-3 py-1 rounded-md bg-accent/10 text-accent text-xs font-bold">高准确率</span>
            <span class="px-3 py-1 rounded-md bg-primary/10 text-primary text-xs font-bold">段落级溯源</span>
          </div>
        </div>

        {/* Feature 2: Side */}
        <div class="reveal md:col-span-4 bento-card flex flex-col justify-between" style="transition-delay: 100ms">
          <div>
            <div class="w-12 h-12 bg-accent/10 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="lucide:file-text" class="text-accent w-6 h-6" />
            </div>
            <h3 class="text-2xl mb-4">缺失条款智能补全</h3>
            <p class="text-muted">
              通过语义相似度自动发现缺失条款，并基于上下文生成插入建议，保持文档完整性。
            </p>
          </div>
          <div class="flex items-center gap-2 text-accent font-bold text-sm">
            了解详情 <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </div>
        </div>

        {/* Feature 3: Small */}
        <div class="reveal md:col-span-4 bento-card flex flex-col justify-between group overflow-hidden relative" style="transition-delay: 200ms">
          <div class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity duration-500">
            <div class="w-full h-full bg-primary/5 flex items-center justify-center scale-150 rotate-12">
               <div class="w-32 h-32 border-4 border-primary/20 border-t-primary rounded-full animate-spin"></div>
            </div>
          </div>
          <div class="relative z-10">
            <div class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center mb-6">
              <Icon name="lucide:bar-chart-3" class="text-primary w-6 h-6" />
            </div>
            <h3 class="text-xl mb-2">可视化审查进度</h3>
            <p class="text-sm text-muted line-clamp-2">
              实时展示向量化、检索、审查、完成的全生命周期状态追踪。
            </p>
          </div>
        </div>

        {/* Feature 4: Semi-Large */}
        <div class="reveal md:col-span-8 bento-card bg-gradient-to-br from-[#8B5CF6] to-[#6D28D9] dark:from-[#0B123B] dark:to-[#030620] border-none text-white flex flex-col justify-between" style="transition-delay: 300ms">
          <div>
            <h3 class="text-2xl mb-4 font-bold">本地数据中心与多模型联邦</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="p-4 bg-white/10 rounded-2xl backdrop-blur-sm">
                <h4 class="font-bold mb-2 flex items-center gap-2 italic">
                  <Icon name="lucide:shield-check" class="w-4 h-4" /> 隐私至上 (Local First)
                </h4>
                <p class="text-xs text-white/80 leading-relaxed">敏感数据本地脱敏，IndexedDB 本地向量库，企业级完全离线部署支持。</p>
              </div>
              <div class="p-4 bg-white/10 rounded-2xl backdrop-blur-sm">
                <h4 class="font-bold mb-2 flex items-center gap-2">
                  <Icon name="lucide:cpu" class="w-4 h-4" /> 模型联邦
                </h4>
                <p class="text-xs text-white/80 leading-relaxed">Embedding 与 LLM 解耦。支持 DeepSeek, Moonshot, DashScope 等主流国产模型。</p>
              </div>
            </div>
          </div>
          <div class="flex items-center gap-2 text-white/80 text-sm mt-6">
            <Icon name="lucide:lock" class="w-4 h-4" /> 满足律所、金融机构最严苛的数据合规要求
          </div>
        </div>
      </div>
    </section>

    <!-- Product Preview Section -->
    <section class="px-6 py-24 max-w-7xl mx-auto overflow-hidden">
      <div class="reveal text-center mb-16">
        <h2 class="text-3xl md:text-5xl mb-4 text-[#101010] dark:text-white">产品实战预览</h2>
        <p class="text-muted">直观、高效、智能的合同审查交互体验</p>
      </div>

      <div class="space-y-24">
        {/* Step 1: Scanning */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="reveal reveal-right">
            <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-primary/10 text-primary text-xs font-bold mb-6">
              <Icon name="lucide:refresh-ccw" class="w-3 h-3 animate-spin" /> 智能扫描中
            </div>
            <h3 class="text-3xl md:text-4xl mb-6">逐条核查，不遗漏任何细节</h3>
            <p class="text-muted text-lg mb-8 leading-relaxed">
              UniClause 会模拟专家思路，对合同中的每一个预设核查点进行深度检索与分析。
              进度条实时同步审查状态，让您对审核工作量与进度了如指掌。
            </p>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <div class="p-1 rounded-full bg-green-500/10 text-green-600 mt-1"><Icon name="lucide:check-circle-2" class="w-4 h-4" /></div>
                <span class="text-muted">实时反馈审查进度（向量化 → 检索 → 完成）</span>
              </li>
              <li class="flex items-start gap-3">
                <div class="p-1 rounded-full bg-green-500/10 text-green-600 mt-1"><Icon name="lucide:check-circle-2" class="w-4 h-4" /></div>
                <span class="text-muted">长合同毫秒级分块匹配，突破 Token 限制</span>
              </li>
            </ul>
          </div>
          <div class="reveal reveal-left">
            <div class="relative group">
              <div class="absolute inset-0 bg-primary/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 -z-10"></div>
              <div class="rounded-[2.5rem] border border-border-light dark:border-border-dark overflow-hidden shadow-2xl bg-white dark:bg-[#030620] aspect-video flex relative">
                {/* Simulated Document Left */}
                <div class="w-1/2 p-6 border-r border-border-light dark:border-border-dark flex flex-col gap-3">
                  <div class="h-4 bg-black/5 dark:bg-white/5 rounded w-3/4"></div>
                  <div class="h-3 bg-black/5 dark:bg-white/5 rounded w-full"></div>
                  <div class="h-3 bg-black/5 dark:bg-white/5 rounded w-5/6"></div>
                  <div class="h-3 bg-black/5 dark:bg-white/5 rounded w-full"></div>
                  <div class="h-3 bg-black/5 dark:bg-white/5 rounded w-4/5"></div>
                  <div class="mt-4 h-4 bg-primary/20 rounded-full w-2/3 animate-pulse"></div>
                  <div class="h-3 bg-primary/10 rounded w-full"></div>
                  <div class="h-3 bg-primary/10 rounded w-5/6"></div>
                </div>
                {/* Scanning Side Right */}
                <div class="w-1/2 p-6 flex flex-col items-center justify-center bg-primary/5">
                  <div class="relative">
                    <div class="w-24 h-24 border-2 border-primary/20 border-t-primary rounded-full animate-spin"></div>
                    <div class="absolute inset-0 flex items-center justify-center">
                      <Icon name="lucide:refresh-ccw" class="w-8 h-8 text-primary" />
                    </div>
                  </div>
                  <div class="mt-6 text-center">
                    <div class="text-[10px] font-bold text-primary uppercase tracking-[0.2em] mb-1">Analyzing Clause 6/12</div>
                    <div class="w-32 h-1 bg-primary/20 rounded-full overflow-hidden">
                      <div class="w-1/2 h-full bg-primary"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {/* Step 2: Risk Identified */}
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
          <div class="reveal reveal-left lg:order-2">
            <div>
              <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-bold mb-6">
                <Icon name="lucide:zap" class="w-3 h-3" /> 风险智能定位
              </div>
              <h3 class="text-3xl md:text-4xl mb-6">精准识别风险，一键修订</h3>
              <p class="text-muted text-lg mb-8 leading-relaxed">
                AI 自动标记高、中、低风险条款。高光显示原文争议处，同步提供专业法律建议。
                支持“一键替换”，极大缩短法务从发现问题到出具初稿的时间。
              </p>
              <ul class="space-y-4">
                <li class="flex items-start gap-3">
                  <div class="p-1 rounded-full bg-green-500/10 text-green-600 mt-1"><Icon name="lucide:check-circle-2" class="w-4 h-4" /></div>
                  <span class="text-muted">原文与修订建议并排比对，交互流畅</span>
                </li>
                <li class="flex items-start gap-3">
                  <div class="p-1 rounded-full bg-green-500/10 text-green-600 mt-1"><Icon name="lucide:check-circle-2" class="w-4 h-4" /></div>
                  <span class="text-muted">RAG 支撑的结论，每个修订建议都有法理依据</span>
                </li>
              </ul>
            </div>
          </div>
          <div class="reveal reveal-right lg:order-1">
            <div class="relative group">
              <div class="absolute inset-0 bg-accent/20 blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700 -z-10"></div>
              <div class="rounded-[2.5rem] border border-border-light dark:border-border-dark overflow-hidden shadow-2xl bg-white dark:bg-[#0B123B] aspect-video flex relative">
                {/* Legal Document Base */}
                <div class="w-2/3 p-8 space-y-4">
                  <div class="flex items-center gap-2 mb-4">
                    <Icon name="lucide:file-text" class="w-4 h-4 text-muted" />
                    <span class="text-[10px] font-mono text-muted">HSBC-MT760-2026.docx</span>
                  </div>
                  <div class="space-y-2 opacity-30">
                    <div class="h-2 bg-black/20 dark:bg-white/10 rounded w-full"></div>
                    <div class="h-2 bg-black/20 dark:bg-white/10 rounded w-full"></div>
                  </div>
                  <div class="p-4 bg-red-500/5 border-l-2 border-red-500/30 rounded-r-lg">
                    <div class="h-2 bg-red-500/20 rounded w-full mb-2"></div>
                    <div class="h-2 bg-red-500/20 rounded w-5/6"></div>
                  </div>
                  <div class="space-y-2 opacity-30">
                    <div class="h-2 bg-black/20 dark:bg-white/10 rounded w-full"></div>
                    <div class="h-2 bg-black/20 dark:bg-white/10 rounded w-4/5"></div>
                  </div>
                </div>
                {/* AI Sidebar Overlay */}
                <div class="w-1/3 bg-white/5 border-l border-white/10 p-4 flex flex-col gap-4 backdrop-blur-sm">
                  <div class="px-2 py-1 bg-red-500/10 border border-red-500/20 rounded text-[8px] text-red-500 font-bold uppercase w-fit">High Risk</div>
                  <div class="p-3 bg-primary/10 rounded-lg border border-primary/20">
                    <div class="text-[9px] font-bold text-primary mb-2 flex items-center gap-1">
                      <Icon name="lucide:zap" class="w-3 h-3" /> 修订建议 (AI)
                    </div>
                    <div class="space-y-1">
                      <div class="h-1 bg-primary/30 rounded-full w-full"></div>
                      <div class="h-1 bg-primary/30 rounded-full w-full"></div>
                      <div class="h-1 bg-primary/30 rounded-full w-4/5"></div>
                    </div>
                  </div>
                  <button class="mt-auto px-4 py-2 bg-primary text-white text-[10px] font-bold rounded-lg shadow-lg hover:brightness-110 transition-all">一键替换原文</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Selling Points -->
    <section id="selling-points" class="py-24 bg-surface-light dark:bg-surface-dark/50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="reveal mb-16">
          <h2 class="text-3xl md:text-5xl mb-4">核心卖点</h2>
          <p class="text-muted">为什么选择 UniClause？我们的差异化优势</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sellingPoints.map((point, index) => (
            <div class={`reveal p-8 rounded-3xl bg-white dark:bg-[#030620] border border-border-light dark:border-border-dark hover:shadow-xl transition-all h-full`} style={`transition-delay: ${index * 100}ms`}>
              <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center text-primary mb-6">
                <Icon name={point.icon} class="w-6 h-6" />
              </div>
