---
import { Icon } from 'astro-icon/components';
import Headline from '../ui/Headline.astro';
import WidgetWrapper from '../ui/WidgetWrapper.astro';
import ItemGrid from '../ui/ItemGrid.astro';
import type { Content as Props } from '@/types';
import Image from '@/components/common/Image.astro';
import Button from '@/components/ui/Button.astro';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  callToAction,
  items = [],
  columns,
  image = await Astro.slots.render('image'),
  isReversed = false,
  isAfterContent = false,

  id,
  isDark = false,
  classes = {},
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper
  id={id}
  isDark={isDark}
  containerClass={`max-w-7xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''} ${classes?.['container'] ?? ''}`}
  bg={bg}
>
  <Headline
    title={title}
    subtitle={subtitle}
    tagline={tagline}
    classes={{
      container: 'max-w-xl sm:mx-auto lg:max-w-2xl',
      title: 'text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading',
      subtitle: 'max-w-3xl mx-auto sm:text-center text-xl text-muted dark:text-slate-400',
      tagline: 'text-sm font-bold uppercase tracking-[0.2em] text-accent mb-3',
    }}
  />
  <div class='mx-auto max-w-7xl px-4 md:px-8'>
    <div class={`md:flex md:gap-16 items-center ${isReversed ? 'md:flex-row-reverse' : ''}`}>
      <div class='self-center md:basis-1/2'>
        {content && (
          <div class='mb-12 text-lg leading-relaxed text-muted dark:text-slate-400' set:html={content} />
        )}

        {
          callToAction && (
            <div class='mb-8 mt-[-20px]'>
              <Button variant='link' {...callToAction} />
            </div>
          )
        }

        <div class='space-y-5'>
          {items.map((item, index) => (
            <div 
              class='intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade card-bento flex items-start gap-4 p-5'
              style={`animation-delay: ${index * 100}ms`}
            >
              <div class='flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-gradient-to-br from-primary to-accent'>
                <Icon name='tabler:check' class='h-3.5 w-3.5 text-white' />
              </div>
              <div>
                <h4 class='font-semibold text-default dark:text-white mb-1'>{item.title}</h4>
                {item.description && (
                  <p class='text-muted text-sm leading-relaxed'>{item.description}</p>
                )}
              </div>
            </div>
          ))}
        </div>
      </div>
      <div aria-hidden='true' class='mt-12 md:mt-0 md:basis-1/2'>
        {
          image && (
            <div class='relative m-auto max-w-4xl'>
              <div class='absolute -inset-4 rounded-3xl bg-gradient-to-r from-primary/20 via-accent/20 to-primary/20 blur-2xl opacity-50'></div>
              {typeof image === 'string' ? (
                <Fragment set:html={image} />
              ) : (
                <Image
                  class='relative mx-auto w-full rounded-2xl border border-hairline shadow-2xl'
                  width={500}
                  height={500}
                  widths={[400, 768]}
                  sizes='(max-width: 768px) 100vw, 432px'
                  layout='responsive'
                  {...image}
                />
              )}
            </div>
          )
        }
      </div>
    </div>
  </div>
</WidgetWrapper>