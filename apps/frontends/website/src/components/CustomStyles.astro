---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono';
import '@fontsource/outfit';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Outfit';
    --aw-font-mono: 'JetBrains Mono';

    --aw-color-primary: #7C3AED;
    --aw-color-primary-rgb: 124, 58, 237;
    --aw-color-secondary: #5B21B6;
    --aw-color-accent: #C084FC;
    --aw-color-primary-glow: rgba(124, 58, 237, 0.3);

    --aw-color-text-heading: #1E1B4B;
    --aw-color-text-default: #1E1B4B;
    --aw-color-text-muted: rgba(30, 27, 75, 0.6);
    --aw-color-bg-page: #FCFCFD;
    --aw-color-bg-surface: #FFFFFF;
    --aw-color-border: rgba(124, 58, 237, 0.1);
    --aw-color-bg-dark: #F9F8FF;
    --aw-color-bg-darker: #F3F0FF;

    --aw-selection-bg: rgba(124, 58, 237, 0.2);
    --aw-selection-text: #7C3AED;
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Outfit';
    --aw-font-mono: 'JetBrains Mono';

    --aw-color-primary: #7C3AED;
    --aw-color-primary-rgb: 124, 58, 237;
    --aw-color-secondary: #5B21B6;
    --aw-color-accent: #C084FC;
    --aw-color-primary-glow: rgba(124, 58, 237, 0.3);

    --aw-color-text-heading: #FDFCFE;
    --aw-color-text-default: #FDFCFE;
    --aw-color-text-muted: rgba(253, 252, 254, 0.6);
    --aw-color-bg-page: #0B0A1F;
    --aw-color-bg-surface: #161436;
    --aw-color-border: rgba(255, 255, 255, 0.08);
    --aw-color-bg-dark: #1A183D;
    --aw-color-bg-darker: #0B0A1F;

    --aw-selection-bg: rgba(124, 58, 237, 0.2);
    --aw-selection-text: #FDFCFE;
  }

  .dark::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: -1;
    background:
      radial-gradient(ellipse 80% 50% at 20% 0%, rgba(124, 58, 237, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(192, 132, 252, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 40% 30% at 50% 50%, rgba(91, 33, 182, 0.04) 0%, transparent 60%);
  }

  ::selection {
    background-color: var(--aw-selection-bg);
    color: var(--aw-selection-text);
  }
</style>