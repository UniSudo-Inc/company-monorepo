---
import '@fontsource-variable/inter';
import '@fontsource/jetbrains-mono';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(0 71 171);
    --aw-color-accent: rgb(139 92 246);

    --aw-color-text-heading: rgb(16 16 16);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);
    --aw-color-bg-surface: rgb(248 250 252);
    --aw-color-border: rgba(16, 16, 16, 0.08);

    --aw-selection-bg: rgb(255 250 250);
    --aw-selection-text: rgb(3 6 32);
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(1 97 239);
    --aw-color-secondary: rgb(0 71 171);
    --aw-color-accent: rgb(139 92 246);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);
    --aw-color-bg-surface: rgb(11 18 59);
    --aw-color-border: rgba(255, 255, 255, 0.1);

    --aw-selection-bg: rgb(255 250 250);
    --aw-selection-text: rgb(3 6 32);
  }

  .dark::before {
    content: '';
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    pointer-events: none;
    z-index: -1;
    background: 
      radial-gradient(ellipse 80% 50% at 20% 0%, rgba(1, 97, 239, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse 60% 40% at 80% 100%, rgba(139, 92, 246, 0.06) 0%, transparent 50%),
      radial-gradient(ellipse 40% 30% at 50% 50%, rgba(1, 71, 171, 0.04) 0%, transparent 60%);
  }

  ::selection {
    background-color: var(--aw-selection-bg);
    color: var(--aw-selection-text);
  }
</style>